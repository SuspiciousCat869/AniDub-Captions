background-color: #00000000;
}

c0000000
00:00:03.710 --> 00:00:06.800 line:90% align:center
<Default><b>[breathing shakily]</b></Default>

c0000001
00:00:09.300 --> 00:00:10.340 line:90% align:center
<Default><b>[buzzing]</b></Default>

c0000002
00:00:26.530 --> 00:00:27.990 line:90% align:center
<Default><b>[TALISMAN]
A question has been tickling</b></Default>

c0000003
00:00:28.070 --> 00:00:29.820 line:90% align:center
<Default><b>the back of my mind lately,</b></Default>

c0000004
00:00:29.910 --> 00:00:31.450 line:90% align:center
<Default><b>and I cannot help but ask, why?</b></Default>

c0000005
00:00:32.160 --> 00:00:34.990 line:90% align:center
<Default><b>Why would Vichyssoise,
one of our trump cards, fall?</b></Default>

c0000006
00:00:35.490 --> 00:00:36.790 line:90% align:center
<Default><b>Someone not many people,</b></Default>

c0000007
00:00:36.870 --> 00:00:38.620 line:90% align:center
<Default><b>even from the Lou
and the Zoa families,</b></Default>

c0000008
00:00:38.710 --> 00:00:39.790 line:90% align:center
<Default><b>can rival?</b></Default>

c0000009
00:00:40.210 --> 00:00:42.460 line:90% align:center
<Default><b>The answer truly escapes me,
you see.</b></Default>

c0000010
00:00:43.210 --> 00:00:45.920 line:90% align:center
<Default><b>I wouldn't go around
spilling intel if I were you.</b></Default>

c0000011
00:00:46.550 --> 00:00:47.380 line:90% align:center
<Default><b>Tell me...</b></Default>

c0000012
00:00:47.460 --> 00:00:49.930 line:90% align:center
<Default><b>was it you
who defeated Vichyssoise?</b></Default>

c0000013
00:00:50.010 --> 00:00:52.550 line:90% align:center
<Default><b>Former eleventh
of the Saint Disciples?</b></Default>

c0000014
00:00:53.140 --> 00:00:55.010 line:90% align:center
<Default><b>I don't have
to tell you anything.</b></Default>

c0000015
00:00:55.850 --> 00:00:58.520 line:90% align:center
<Default><b>Well, that non-answer
is plenty enough for me.</b></Default>

c0000016
00:00:59.230 --> 00:01:02.100 line:90% align:center
<Default><b>Just in case, I sent
another assassin this way.</b></Default>

c0000017
00:01:02.190 --> 00:01:04.150 line:90% align:center
<Default><b>Unfortunately,
they have yet to arrive.</b></Default>

c0000018
00:01:04.480 --> 00:01:05.820 line:90% align:center
<Default><b>[exhales]
Assassin?</b></Default>

c0000019
00:01:06.400 --> 00:01:08.240 line:90% align:center
<Default><b>Pity.
But all is well.</b></Default>

c0000020
00:01:08.940 --> 00:01:10.240 line:90% align:center
<Default><b>The longer I dally here,</b></Default>

c0000021
00:01:10.320 --> 00:01:12.700 line:90% align:center
<Default><b>the more I will be missed
at the royal palace.</b></Default>

c0000022
00:01:12.780 --> 00:01:13.990 line:90% align:center
<Default><b>I am late for the occas--</b></Default>

c0000023
00:01:14.070 --> 00:01:14.950 line:90% align:center
<Default><b>[Iska grunts]</b></Default>

c0000024
00:01:15.330 --> 00:01:16.410 line:90% align:center
<Default><b>LAST CRUSADE:
NIGHT OF THE WITCH HUNT</b></Default>

c0000025
00:01:16.490 --> 00:01:17.450 line:90% align:center
<Default><b>Finished?</b></Default>

c0000026
00:01:17.540 --> 00:01:19.540 line:90% align:center
<Default><b>Because I was not done talking.</b></Default>

c0000027
00:01:20.160 --> 00:01:21.160 line:90% align:center
<Default><b>[ISKA]
Too bad.</b></Default>

c0000028
00:01:22.540 --> 00:01:23.710 line:90% align:center
<Default><b>[Iska grunts]</b></Default>

c0000029
00:01:26.800 --> 00:01:27.800 line:90% align:center
<Default><b>[grunts]</b></Default>

c0000030
00:01:29.760 --> 00:01:30.800 line:90% align:center
<Default><b>Hm.</b></Default>

c0000031
00:01:30.880 --> 00:01:32.890 line:90% align:center
<Default><b>I can't let you
come any closer.</b></Default>

c0000032
00:01:33.220 --> 00:01:34.640 line:90% align:center
<Default><b>That'd be dangerous.</b></Default>

c0000033
00:01:34.720 --> 00:01:35.720 line:90% align:center
<Default><b>[exhales]</b></Default>

c0000034
00:01:36.600 --> 00:01:38.020 line:90% align:center
<Default><b>The Great Eagre.</b></Default>

c0000035
00:01:40.480 --> 00:01:41.980 line:90% align:center
<Default><b>♪</b></Default>

c0000036
00:01:42.060 --> 00:01:43.230 line:90% align:center
<Default><b>[Iska grunts]</b></Default>

c0000037
00:01:43.310 --> 00:01:44.270 line:90% align:center
<Default><b>[groans]</b></Default>

c0000038
00:01:44.350 --> 00:01:45.610 line:90% align:center
<Default><b>[ISKA]
It's crushing my arm!</b></Default>

c0000039
00:01:47.440 --> 00:01:48.280 line:90% align:center
<Default><b>[exhales]</b></Default>

c0000040
00:01:48.360 --> 00:01:51.200 line:90% align:center
<Default><b>[TALISMAN] Avoiding capture
right in the nick of time.</b></Default>

c0000041
00:01:51.280 --> 00:01:52.860 line:90% align:center
<Default><b>For such a young man,</b></Default>

c0000042
00:01:52.950 --> 00:01:54.570 line:90% align:center
<Default><b>you are a seasoned fighter.</b></Default>

c0000043
00:01:55.070 --> 00:01:58.620 line:90% align:center
<Default><b>A war-dog and a destroyer
bred for the battlefield.</b></Default>

c0000044
00:01:59.580 --> 00:02:01.250 line:90% align:center
<Default><b>[rumbling]</b></Default>

c0000045
00:02:01.330 --> 00:02:02.330 line:90% align:center
<Default><b>[Iska gasps]</b></Default>

c0000046
00:02:03.370 --> 00:02:04.420 line:90% align:center
<Default><b>[chuckles]</b></Default>

c0000047
00:02:05.250 --> 00:02:06.250 line:90% align:center
<Default><b>[grunts]</b></Default>

c0000048
00:02:06.790 --> 00:02:07.790 line:90% align:center
<Default><b>[Iska groans]</b></Default>

c0000049
00:02:09.460 --> 00:02:10.460 line:90% align:center
<Default><b>[grunts]</b></Default>

c0000050
00:02:10.960 --> 00:02:12.220 line:90% align:center
<Default><b>[ISKA]
If I time it right,</b></Default>

c0000051
00:02:12.300 --> 00:02:14.220 line:90% align:center
<Default><b>I can move in
faster than the waves!</b></Default>

c0000052
00:02:14.970 --> 00:02:18.180 line:90% align:center
<Default><b>An Imperial soldier
without a gun is a rare sight.</b></Default>

c0000053
00:02:18.260 --> 00:02:19.430 line:90% align:center
<Default><b>But there's one thing.</b></Default>

c0000054
00:02:19.520 --> 00:02:20.770 line:90% align:center
<Default><b>Could it be the barrier?</b></Default>

c0000055
00:02:21.390 --> 00:02:23.060 line:90% align:center
<Default><b>[shatters]</b></Default>

c0000056
00:02:23.850 --> 00:02:24.850 line:90% align:center
<Default><b>Oh?</b></Default>

c0000057
00:02:25.350 --> 00:02:27.060 line:90% align:center
<Default><b>What gave it away?</b></Default>

c0000058
00:02:27.400 --> 00:02:28.400 line:90% align:center
<Default><b>Hunch.</b></Default>

c0000059
00:02:28.730 --> 00:02:29.650 line:90% align:center
<Default><b>[chuckles]</b></Default>

c0000060
00:02:29.730 --> 00:02:32.030 line:90% align:center
<Default><b>Paring your expertise
down to a "hunch?"</b></Default>

c0000061
00:02:32.530 --> 00:02:35.780 line:90% align:center
<Default><b>Saint Disciples do truly belong
in a class of their own.</b></Default>

c0000062
00:02:35.860 --> 00:02:37.820 line:90% align:center
<Default><b>A dangerous problem
in this age.</b></Default>

c0000063
00:02:37.910 --> 00:02:39.870 line:90% align:center
<Default><b>-Hmm.
-[Talisman chuckles]</b></Default>

c0000064
00:02:39.950 --> 00:02:42.250 line:90% align:center
<Default><b>It was quite dull
without someone to play with.</b></Default>

c0000065
00:02:43.830 --> 00:02:44.830 line:90% align:center
<Default><b>[Iska gasps]</b></Default>

c0000066
00:02:44.920 --> 00:02:45.960 line:90% align:center
<Default><b>[grunts]</b></Default>

c0000067
00:02:46.040 --> 00:02:48.590 line:90% align:center
<Default><b>[TALISMAN] A wave is
a ripple of dynamic energy</b></Default>

c0000068
00:02:48.670 --> 00:02:50.210 line:90% align:center
<Default><b>that has acquired a vector.</b></Default>

c0000069
00:02:50.960 --> 00:02:52.630 line:90% align:center
<Default><b>It is the very physical quality</b></Default>

c0000070
00:02:52.710 --> 00:02:54.800 line:90% align:center
<Default><b>that creates mass
and acceleration.</b></Default>

c0000071
00:02:55.340 --> 00:02:57.430 line:90% align:center
<Default><b>But I assume
you already knew that.</b></Default>

c0000072
00:02:57.970 --> 00:02:58.850 line:90% align:center
<Default><b>Huh?</b></Default>

c0000073
00:02:58.930 --> 00:03:00.180 line:90% align:center
<Default><b>It would still be wise of you</b></Default>

c0000074
00:03:00.260 --> 00:03:02.310 line:90% align:center
<Default><b>not to lump
all wave users in together.</b></Default>

c0000075
00:03:02.390 --> 00:03:04.560 line:90% align:center
<Default><b>Our levels of expertise
vary widely.</b></Default>

c0000076
00:03:05.020 --> 00:03:07.060 line:90% align:center
<Default><b>[Iska groans]</b></Default>

c0000077
00:03:09.060 --> 00:03:11.280 line:90% align:center
<Default><b>[ISKA]
Crap, I let my guard down!</b></Default>

c0000078
00:03:11.980 --> 00:03:13.780 line:90% align:center
<Default><b>What else is
he holding back from me?</b></Default>

c0000079
00:03:15.200 --> 00:03:17.570 line:90% align:center
<Default><b>[TALISMAN]
The Vicious Tyrant, Talisman.</b></Default>

c0000080
00:03:18.070 --> 00:03:19.280 line:90% align:center
<Default><b>Ignore the name,</b></Default>

c0000081
00:03:19.370 --> 00:03:22.120 line:90% align:center
<Default><b>as it does not at all
reflect my true sensibilities.</b></Default>

c0000082
00:03:22.200 --> 00:03:23.040 line:90% align:center
<Default><b>[scoffs]</b></Default>

c0000083
00:03:23.120 --> 00:03:24.330 line:90% align:center
<Default><b>Sure about that?</b></Default>

c0000084
00:03:25.040 --> 00:03:26.290 line:90% align:center
<Default><b>It suits you.</b></Default>

c0000085
00:03:26.370 --> 00:03:27.540 line:90% align:center
<Default><b>[spits]</b></Default>

c0000086
00:03:27.620 --> 00:03:29.290 line:90% align:center
<Default><b>[all panting]</b></Default>

c0000087
00:03:29.380 --> 00:03:31.880 line:90% align:center
<Default><b>Putting our lives on the line
to play escort.</b></Default>

c0000088
00:03:32.300 --> 00:03:34.510 line:90% align:center
<Default><b>All for one measly
astral sticker.</b></Default>

c0000089
00:03:35.340 --> 00:03:37.590 line:90% align:center
<Default><b>This job is turning
into a real mess.</b></Default>

c0000090
00:03:37.680 --> 00:03:39.340 line:90% align:center
<Default><b>-Huh? What was that?
-[gunshot firing]</b></Default>

c0000091
00:03:39.760 --> 00:03:41.220 line:90% align:center
<Default><b>Nothing, keep running.</b></Default>

c0000092
00:03:41.310 --> 00:03:42.220 line:90% align:center
<Default><b>[MISMIS]
Can't you do anything</b></Default>

c0000093
00:03:42.310 --> 00:03:44.060 line:90% align:center
<Default><b>to take care of those guys,
Sisbell?</b></Default>

c0000094
00:03:44.140 --> 00:03:45.270 line:90% align:center
<Default><b>[gunshots firing]</b></Default>

c0000095
00:03:45.350 --> 00:03:46.940 line:90% align:center
<Default><b>[NENE]
Maybe blast them away?</b></Default>

c0000096
00:03:47.440 --> 00:03:48.560 line:90% align:center
<Default><b>If I were a grenade,</b></Default>

c0000097
00:03:48.650 --> 00:03:50.860 line:90% align:center
<Default><b>then I wouldn't need
to hire a bodyguard!</b></Default>

c0000098
00:03:50.940 --> 00:03:51.860 line:90% align:center
<Default><b>Unless...</b></Default>

c0000099
00:03:51.940 --> 00:03:54.320 line:90% align:center
<Default><b>there is another way
that I can buy us some time!</b></Default>

c0000100
00:03:55.110 --> 00:03:57.200 line:90% align:center
<Default><b>Stars, show me your past.</b></Default>

c0000101
00:03:57.650 --> 00:03:58.990 line:90% align:center
<Default><b>And come to light!</b></Default>

c0000102
00:03:59.620 --> 00:04:00.660 line:90% align:center
<Default><b>[SOLDIER]
What?</b></Default>

c0000103
00:04:01.580 --> 00:04:02.580 line:90% align:center
<Default><b>Hm.</b></Default>

c0000104
00:04:03.080 --> 00:04:05.330 line:90% align:center
<Default><b>[exhales]
Well? Not a grenade,</b></Default>

c0000105
00:04:05.750 --> 00:04:07.210 line:90% align:center
<Default><b>but that should hold them off.</b></Default>

c0000106
00:04:07.580 --> 00:04:08.500 line:90% align:center
<Default><b>Yeah.</b></Default>

c0000107
00:04:08.580 --> 00:04:10.460 line:90% align:center
<Default><b>But it won't fool them
a second time.</b></Default>

c0000108
00:04:11.080 --> 00:04:12.590 line:90% align:center
<Default><b>We need to leave
before we give them</b></Default>

c0000109
00:04:12.670 --> 00:04:14.840 line:90% align:center
<Default><b>the opportunity
to surround us on all sides.</b></Default>

c0000110
00:04:15.630 --> 00:04:17.720 line:90% align:center
<Default><b>Got any rooms upstairs
we can jump out of?</b></Default>

c0000111
00:04:19.090 --> 00:04:20.430 line:90% align:center
<Default><b>[SISBELL]
We have the corner guest room</b></Default>

c0000112
00:04:20.510 --> 00:04:21.760 line:90% align:center
<Default><b>on the second floor.</b></Default>

c0000113
00:04:22.140 --> 00:04:23.720 line:90% align:center
<Default><b>[Mismis shivering]</b></Default>

c0000114
00:04:23.810 --> 00:04:25.430 line:90% align:center
<Default><b>Did the temperature just drop?</b></Default>

c0000115
00:04:25.770 --> 00:04:27.180 line:90% align:center
<Default><b>[NENE]
That's what I was wondering.</b></Default>

c0000116
00:04:27.270 --> 00:04:28.770 line:90% align:center
<Default><b>-Huh?
-[NENE] Huh?</b></Default>

c0000117
00:04:29.480 --> 00:04:30.810 line:90% align:center
<Default><b>[GRUGELL]
Children.</b></Default>

c0000118
00:04:30.900 --> 00:04:33.520 line:90% align:center
<Default><b>Come out, come out,
wherever you are.</b></Default>

c0000119
00:04:33.610 --> 00:04:34.610 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000120
00:04:34.980 --> 00:04:35.980 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000121
00:04:36.070 --> 00:04:36.940 line:90% align:center
<Default><b>[rumbling]</b></Default>

c0000122
00:04:37.030 --> 00:04:38.360 line:90% align:center
<Default><b>[Grugell chuckles]</b></Default>

c0000123
00:04:38.450 --> 00:04:40.320 line:90% align:center
<Default><b>[GRUGELL]
Run from me all you like,</b></Default>

c0000124
00:04:40.410 --> 00:04:42.240 line:90% align:center
<Default><b>but you won't be
able to hide forever</b></Default>

c0000125
00:04:42.320 --> 00:04:44.200 line:90% align:center
<Default><b>with Lady Sisbell at your hip.</b></Default>

c0000126
00:04:44.660 --> 00:04:45.660 line:90% align:center
<Default><b>[JHIN]
Incredible.</b></Default>

c0000127
00:04:46.370 --> 00:04:48.210 line:90% align:center
<Default><b>You're a stubborn old hag,
aren't you?</b></Default>

c0000128
00:04:48.960 --> 00:04:50.040 line:90% align:center
<Default><b>All right, then, granny.</b></Default>

c0000129
00:04:50.120 --> 00:04:51.500 line:90% align:center
<Default><b>Let's get you to bed, now.</b></Default>

c0000130
00:04:52.250 --> 00:04:55.250 line:90% align:center
<Default><b>I would like nothing more
than to retire for the evening.</b></Default>

c0000131
00:04:55.630 --> 00:04:56.800 line:90% align:center
<Default><b>But I've lost patience</b></Default>

c0000132
00:04:56.880 --> 00:04:58.800 line:90% align:center
<Default><b>with the little mice
scuttling underfoot.</b></Default>

c0000133
00:04:59.340 --> 00:05:02.010 line:90% align:center
<Default><b>Give me the girl
so I can stamp you three out.</b></Default>

c0000134
00:05:02.090 --> 00:05:03.390 line:90% align:center
<Default><b>-Not happening.
-[gunshot fires]</b></Default>

c0000135
00:05:03.470 --> 00:05:04.680 line:90% align:center
<Default><b>♪</b></Default>

c0000136
00:05:04.760 --> 00:05:05.760 line:90% align:center
<Default><b>-Let's go!
-[ALL] Yes!</b></Default>

c0000137
00:05:06.180 --> 00:05:07.560 line:90% align:center
<Default><b>[growls]</b></Default>

c0000138
00:05:08.060 --> 00:05:10.020 line:90% align:center
<Default><b>[GRUGELL]
You vermin!</b></Default>

c0000139
00:05:10.100 --> 00:05:11.810 line:90% align:center
<Default><b>Look!
We've got company!</b></Default>

c0000140
00:05:12.350 --> 00:05:13.400 line:90% align:center
<Default><b>[JHIN]
Pay attention!</b></Default>

c0000141
00:05:14.110 --> 00:05:16.530 line:90% align:center
<Default><b>[laughing]</b></Default>

c0000142
00:05:16.610 --> 00:05:18.280 line:90% align:center
<Default><b>[JHIN]
We're less than prey to her.</b></Default>

c0000143
00:05:19.530 --> 00:05:21.910 line:90% align:center
<Default><b>Which means she's sorely
underestimating us.</b></Default>

c0000144
00:05:22.360 --> 00:05:23.530 line:90% align:center
<Default><b>[TALISMAN]
Feel that?</b></Default>

c0000145
00:05:23.620 --> 00:05:25.870 line:90% align:center
<Default><b>Those wounds are from me
converting the wave energy</b></Default>

c0000146
00:05:25.950 --> 00:05:27.700 line:90% align:center
<Default><b>into physical acceleration.</b></Default>

c0000147
00:05:28.580 --> 00:05:30.750 line:90% align:center
<Default><b>Any mages with
the same astral spirit,</b></Default>

c0000148
00:05:31.250 --> 00:05:32.790 line:90% align:center
<Default><b>are capable of this feat.</b></Default>

c0000149
00:05:34.130 --> 00:05:36.210 line:90% align:center
<Default><b>"Any mages?"
Cut the crap.</b></Default>

c0000150
00:05:37.000 --> 00:05:38.710 line:90% align:center
<Default><b>[TALISMAN]
Training at its finest.</b></Default>

c0000151
00:05:39.510 --> 00:05:40.510 line:90% align:center
<Default><b>[thuds]</b></Default>

c0000152
00:05:41.760 --> 00:05:42.760 line:90% align:center
<Default><b>[chuckles]</b></Default>

c0000153
00:05:43.260 --> 00:05:44.260 line:90% align:center
<Default><b>[thwacks]</b></Default>

c0000154
00:05:44.340 --> 00:05:45.350 line:90% align:center
<Default><b>[grunts]</b></Default>

c0000155
00:05:47.390 --> 00:05:48.640 line:90% align:center
<Default><b>[ISKA]
Just like I thought.</b></Default>

c0000156
00:05:48.720 --> 00:05:50.930 line:90% align:center
<Default><b>It's not the initial speed
that makes him fast.</b></Default>

c0000157
00:05:51.560 --> 00:05:53.150 line:90% align:center
<Default><b>His acceleration's unreal.</b></Default>

c0000158
00:05:53.480 --> 00:05:55.690 line:90% align:center
<Default><b>He's riding the momentum
of his astral power!</b></Default>

c0000159
00:05:56.060 --> 00:05:57.020 line:90% align:center
<Default><b>[thuds]</b></Default>

c0000160
00:05:57.820 --> 00:05:58.820 line:90% align:center
<Default><b>[Iska grunts]</b></Default>

c0000161
00:06:02.200 --> 00:06:04.240 line:90% align:center
<Default><b>[TALISMAN]
Physical conversion of waves.</b></Default>

c0000162
00:06:05.030 --> 00:06:07.530 line:90% align:center
<Default><b>It took me six years
to create this technique.</b></Default>

c0000163
00:06:08.200 --> 00:06:09.830 line:90% align:center
<Default><b>And eight years to master it.</b></Default>

c0000164
00:06:10.370 --> 00:06:12.830 line:90% align:center
<Default><b>Thirteen more to get here.
And so...</b></Default>

c0000165
00:06:13.210 --> 00:06:15.380 line:90% align:center
<Default><b>Nearly 30 years of work,
give or take.</b></Default>

c0000166
00:06:16.170 --> 00:06:17.790 line:90% align:center
<Default><b>A skillful man, I'm not.</b></Default>

c0000167
00:06:18.670 --> 00:06:19.670 line:90% align:center
<Default><b>[gasps]</b></Default>

c0000168
00:06:20.550 --> 00:06:22.260 line:90% align:center
<Default><b>[TALISMAN]
But one cannot reach this level</b></Default>

c0000169
00:06:22.340 --> 00:06:24.840 line:90% align:center
<Default><b>with the mental fortitude
of common folk.</b></Default>

c0000170
00:06:25.340 --> 00:06:27.260 line:90% align:center
<Default><b>Young Saint Disciple.</b></Default>

c0000171
00:06:27.350 --> 00:06:28.510 line:90% align:center
<Default><b>Is the truth of my words</b></Default>

c0000172
00:06:28.600 --> 00:06:30.600 line:90% align:center
<Default><b>slowly beginning
to dawn on you?</b></Default>

c0000173
00:06:31.310 --> 00:06:32.730 line:90% align:center
<Default><b>[ISKA]
I can't even evade it?</b></Default>

c0000174
00:06:33.270 --> 00:06:35.480 line:90% align:center
<Default><b>We are two people
of the same cloth.</b></Default>

c0000175
00:06:35.560 --> 00:06:39.020 line:90% align:center
<Default><b>Rending countless bodies in
our wake for a God's power.</b></Default>

c0000176
00:06:40.070 --> 00:06:41.280 line:90% align:center
<Default><b>[Iska groans]</b></Default>

c0000177
00:06:41.360 --> 00:06:42.190 line:90% align:center
<Default><b>[thuds]</b></Default>

c0000178
00:06:42.280 --> 00:06:45.030 line:90% align:center
<Default><b>Yet I have the upper hand,
experience-wise.</b></Default>

c0000179
00:06:46.030 --> 00:06:47.780 line:90% align:center
<Default><b>See the difference
between us now?</b></Default>

c0000180
00:06:48.580 --> 00:06:49.790 line:90% align:center
<Default><b>[ISKA]
I'm not through.</b></Default>

c0000181
00:06:50.200 --> 00:06:51.200 line:90% align:center
<Default><b>[TALISMAN]
What?</b></Default>

c0000182
00:06:51.950 --> 00:06:53.210 line:90% align:center
<Default><b>[groans]</b></Default>

c0000183
00:06:54.460 --> 00:06:56.880 line:90% align:center
<Default><b>You took that blow
to your body head on.</b></Default>

c0000184
00:06:56.960 --> 00:06:58.170 line:90% align:center
<Default><b>[ISKA]
Pretty much, yeah.</b></Default>

c0000185
00:06:58.960 --> 00:07:01.210 line:90% align:center
<Default><b>[TALISMAN] So why are
your lungs not obliterated?</b></Default>

c0000186
00:07:01.670 --> 00:07:03.970 line:90% align:center
<Default><b>[ISKA] Even one second later
releasing the astral art,</b></Default>

c0000187
00:07:04.300 --> 00:07:05.720 line:90% align:center
<Default><b>and I would've been a goner.</b></Default>

c0000188
00:07:06.430 --> 00:07:08.050 line:90% align:center
<Default><b>[chuckles]
Marvelous!</b></Default>

c0000189
00:07:08.140 --> 00:07:09.930 line:90% align:center
<Default><b>Well done surviving that.
[clapping]</b></Default>

c0000190
00:07:10.010 --> 00:07:12.430 line:90% align:center
<Default><b>A compelling adversary,
to say the least.</b></Default>

c0000191
00:07:12.520 --> 00:07:14.690 line:90% align:center
<Default><b>Honestly, I have chills, boy.</b></Default>

c0000192
00:07:14.770 --> 00:07:16.730 line:90% align:center
<Default><b>Funny.
That's my line.</b></Default>

c0000193
00:07:17.860 --> 00:07:19.690 line:90% align:center
<Default><b>[ISKA] He's standing there,
toying with me,</b></Default>

c0000194
00:07:19.770 --> 00:07:20.940 line:90% align:center
<Default><b>and here I am,</b></Default>

c0000195
00:07:21.020 --> 00:07:23.240 line:90% align:center
<Default><b>racing to keep up
and figure out his next move.</b></Default>

c0000196
00:07:23.780 --> 00:07:24.900 line:90% align:center
<Default><b>I'm out of my depth.</b></Default>

c0000197
00:07:25.900 --> 00:07:28.240 line:90% align:center
<Default><b>[TALISMAN] Can you think
of a more perfect stage?</b></Default>

c0000198
00:07:28.660 --> 00:07:30.410 line:90% align:center
<Default><b>This estate is built on a hill,</b></Default>

c0000199
00:07:30.490 --> 00:07:32.580 line:90% align:center
<Default><b>where daybreak can
bathe the interior</b></Default>

c0000200
00:07:32.660 --> 00:07:33.950 line:90% align:center
<Default><b>in a splash of sunlight.</b></Default>

c0000201
00:07:34.040 --> 00:07:35.460 line:90% align:center
<Default><b>[ISKA]
Don't get ahead of yourself.</b></Default>

c0000202
00:07:35.830 --> 00:07:37.830 line:90% align:center
<Default><b>Look outside,
it's only midnight.</b></Default>

c0000203
00:07:38.580 --> 00:07:41.380 line:90% align:center
<Default><b>The glorious sunrise
will not be outshone.</b></Default>

c0000204
00:07:41.460 --> 00:07:43.300 line:90% align:center
<Default><b>For tonight is
the final curtain call</b></Default>

c0000205
00:07:43.380 --> 00:07:46.220 line:90% align:center
<Default><b>for the blinding beam of light
that is the House of Lou.</b></Default>

c0000206
00:07:46.590 --> 00:07:49.600 line:90% align:center
<Default><b>The unfailing star will
burn out at long last.</b></Default>

c0000207
00:07:49.680 --> 00:07:51.810 line:90% align:center
<Default><b>Are you saying
the queen will be cut down?</b></Default>

c0000208
00:07:52.470 --> 00:07:54.100 line:90% align:center
<Default><b>[TALISMAN] [chuckles]
I would never dream</b></Default>

c0000209
00:07:54.180 --> 00:07:55.520 line:90% align:center
<Default><b>of saying such a thing.</b></Default>

c0000210
00:07:55.980 --> 00:07:58.520 line:90% align:center
<Default><b>But who am I to deny
one of your "hunches?"</b></Default>

c0000211
00:07:58.600 --> 00:08:00.230 line:90% align:center
<Default><b>And what's your endgame here?</b></Default>

c0000212
00:08:01.060 --> 00:08:02.270 line:90% align:center
<Default><b>[TALISMAN]
Isn't it obvious?</b></Default>

c0000213
00:08:02.980 --> 00:08:04.820 line:90% align:center
<Default><b>When the starry night
of the Lou ends,</b></Default>

c0000214
00:08:04.900 --> 00:08:06.240 line:90% align:center
<Default><b>morning will come.</b></Default>

c0000215
00:08:06.320 --> 00:08:08.530 line:90% align:center
<Default><b>And with it, the bird
of the new world order</b></Default>

c0000216
00:08:08.610 --> 00:08:10.450 line:90% align:center
<Default><b>will at last take flight.</b></Default>

c0000217
00:08:11.620 --> 00:08:12.660 line:90% align:center
<Default><b>[KISSING]
Disappear.</b></Default>

c0000218
00:08:13.080 --> 00:08:15.790 line:90% align:center
<Default><b>The sooner you're dead,
the sooner I sleep.</b></Default>

c0000219
00:08:16.370 --> 00:08:18.540 line:90% align:center
<Default><b>[MEI]
Whoa, scary.</b></Default>

c0000220
00:08:18.620 --> 00:08:19.710 line:90% align:center
<Default><b>[Mei laughs]</b></Default>

c0000221
00:08:19.790 --> 00:08:21.000 line:90% align:center
<Default><b>So let me guess.</b></Default>

c0000222
00:08:21.080 --> 00:08:23.630 line:90% align:center
<Default><b>Star-body astral spirit
that undoes matter.</b></Default>

c0000223
00:08:24.210 --> 00:08:25.380 line:90% align:center
<Default><b>Am I getting warm yet?</b></Default>

c0000224
00:08:26.720 --> 00:08:28.340 line:90% align:center
<Default><b>[KISSING]
Seeking shelter from up there</b></Default>

c0000225
00:08:28.430 --> 00:08:29.840 line:90% align:center
<Default><b>won't save your life.</b></Default>

c0000226
00:08:30.260 --> 00:08:32.600 line:90% align:center
<Default><b>Word on the street is
second-gen astral spirits</b></Default>

c0000227
00:08:32.680 --> 00:08:33.970 line:90% align:center
<Default><b>born from the planet's core</b></Default>

c0000228
00:08:34.060 --> 00:08:35.310 line:90% align:center
<Default><b>leave their owners
with a distinct</b></Default>

c0000229
00:08:35.390 --> 00:08:36.680 line:90% align:center
<Default><b>purple-colored crest.</b></Default>

c0000230
00:08:36.770 --> 00:08:37.770 line:90% align:center
<Default><b>Show it to me.</b></Default>

c0000231
00:08:38.390 --> 00:08:40.060 line:90% align:center
<Default><b>I will do no such thing.</b></Default>

c0000232
00:08:40.770 --> 00:08:42.560 line:90% align:center
<Default><b>My pride as a lady forbids it.</b></Default>

c0000233
00:08:43.400 --> 00:08:45.150 line:90% align:center
<Default><b>"Pride?"
"A lady?"</b></Default>

c0000234
00:08:46.440 --> 00:08:47.860 line:90% align:center
<Default><b>Don't you gimme that.</b></Default>

c0000235
00:08:47.950 --> 00:08:49.150 line:90% align:center
<Default><b>I'm not an idiot.</b></Default>

c0000236
00:08:49.240 --> 00:08:51.200 line:90% align:center
<Default><b>And I know a witch
when I see one.</b></Default>

c0000237
00:08:53.200 --> 00:08:55.830 line:90% align:center
<Default><b>I'm dying to have
a taste of pureblood witch.</b></Default>

c0000238
00:08:55.910 --> 00:08:58.040 line:90% align:center
<Default><b>I'll figure out
where you're hiding that crest.</b></Default>

c0000239
00:08:58.870 --> 00:09:00.960 line:90% align:center
<Default><b>Maybe I'll start
by tearing off</b></Default>

c0000240
00:09:01.040 --> 00:09:02.790 line:90% align:center
<Default><b>that pretty dress of yours.</b></Default>

c0000241
00:09:03.340 --> 00:09:05.050 line:90% align:center
<Default><b>Ah!
Uh-huh!</b></Default>

c0000242
00:09:05.500 --> 00:09:06.590 line:90% align:center
<Default><b>Wonderful.</b></Default>

c0000243
00:09:07.340 --> 00:09:09.170 line:90% align:center
<Default><b>You were right all along,
Uncle On.</b></Default>

c0000244
00:09:09.590 --> 00:09:12.090 line:90% align:center
<Default><b>Imperial soldiers
are the worst.</b></Default>

c0000245
00:09:13.550 --> 00:09:14.850 line:90% align:center
<Default><b>I'm so relieved!</b></Default>

c0000246
00:09:15.260 --> 00:09:17.270 line:90% align:center
<Default><b>I can crush
every last one of you,</b></Default>

c0000247
00:09:17.350 --> 00:09:19.600 line:90% align:center
<Default><b>without a single care
in the world!</b></Default>

c0000248
00:09:21.650 --> 00:09:23.610 line:90% align:center
<Default><b>Erase them from these halls</b></Default>

c0000249
00:09:24.230 --> 00:09:25.360 line:90% align:center
<Default><b>[chuckles softly]</b></Default>

c0000250
00:09:25.440 --> 00:09:26.440 line:90% align:center
<Default><b>[wind gusting]</b></Default>

c0000251
00:09:31.070 --> 00:09:32.240 line:90% align:center
<Default><b>[MEI]
How about a hard lesson</b></Default>

c0000252
00:09:32.320 --> 00:09:34.200 line:90% align:center
<Default><b>with shards of glass
to the face!</b></Default>

c0000253
00:09:36.030 --> 00:09:37.490 line:90% align:center
<Default><b>-[gasps]
-[Mei laughs]</b></Default>

c0000254
00:09:41.460 --> 00:09:43.580 line:90% align:center
<Default><b>[KISSING] She turns
my astral spirit's defense</b></Default>

c0000255
00:09:43.670 --> 00:09:44.670 line:90% align:center
<Default><b>against me.</b></Default>

c0000256
00:09:45.090 --> 00:09:46.170 line:90% align:center
<Default><b>[MEI]
C'mon.</b></Default>

c0000257
00:09:46.550 --> 00:09:48.510 line:90% align:center
<Default><b>Where's the fun
in an astral spirit like that</b></Default>

c0000258
00:09:48.590 --> 00:09:50.300 line:90% align:center
<Default><b>paired with
a sheltered little witch?</b></Default>

c0000259
00:09:50.800 --> 00:09:51.800 line:90% align:center
<Default><b>Scratch that,</b></Default>

c0000260
00:09:51.880 --> 00:09:54.050 line:90% align:center
<Default><b>real witches love
to play mind games.</b></Default>

c0000261
00:09:54.470 --> 00:09:55.550 line:90% align:center
<Default><b>You're just a doll.</b></Default>

c0000262
00:09:56.220 --> 00:09:57.220 line:90% align:center
<Default><b>Kill her.
[snaps fingers]</b></Default>

c0000263
00:09:57.600 --> 00:09:58.810 line:90% align:center
<Default><b>[gunshots firing]</b></Default>

c0000264
00:09:58.890 --> 00:10:02.060 line:90% align:center
<Default><b>"Doll" is the last word
I'd call a descendant.</b></Default>

c0000265
00:10:02.440 --> 00:10:03.270 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000266
00:10:03.350 --> 00:10:05.520 line:90% align:center
<Default><b>[CAPTAIN] It was point blank
and still nothing?</b></Default>

c0000267
00:10:05.610 --> 00:10:07.770 line:90% align:center
<Default><b>Our astral control
is unmatched.</b></Default>

c0000268
00:10:07.860 --> 00:10:10.030 line:90% align:center
<Default><b>Your bullets mean
nothing to a Zoa.</b></Default>

c0000269
00:10:10.110 --> 00:10:11.780 line:90% align:center
<Default><b>Oh, that was a slip.</b></Default>

c0000270
00:10:12.200 --> 00:10:13.950 line:90% align:center
<Default><b>Uncle On said that's a secret.</b></Default>

c0000271
00:10:14.360 --> 00:10:16.660 line:90% align:center
<Default><b>All the more reason
for you to die here.</b></Default>

c0000272
00:10:16.740 --> 00:10:17.780 line:90% align:center
<Default><b>[glass shatters]</b></Default>

c0000273
00:10:17.870 --> 00:10:18.740 line:90% align:center
<Default><b>Uh.</b></Default>

c0000274
00:10:18.830 --> 00:10:20.700 line:90% align:center
<Default><b>[MEI]
"Ruined King Hurricane."</b></Default>

c0000275
00:10:21.410 --> 00:10:22.410 line:90% align:center
<Default><b>Activate.</b></Default>

c0000276
00:10:23.250 --> 00:10:25.130 line:90% align:center
<Default><b>Thorns!
Rip that woman apart--</b></Default>

c0000277
00:10:25.210 --> 00:10:26.420 line:90% align:center
<Default><b>Didn't I tell you?</b></Default>

c0000278
00:10:27.170 --> 00:10:28.840 line:90% align:center
<Default><b>I'm gonna show you
why they call me</b></Default>

c0000279
00:10:28.920 --> 00:10:30.630 line:90% align:center
<Default><b>the "Incessant Tempest."</b></Default>

c0000280
00:10:30.710 --> 00:10:33.720 line:90% align:center
<Default><b>So this is bye-bye,
my cute little witch.</b></Default>

c0000281
00:10:35.390 --> 00:10:38.390 line:90% align:center
<Default><b>[firing]</b></Default>

c0000282
00:10:41.060 --> 00:10:42.730 line:90% align:center
<Default><b>First, I would
like to thank you.</b></Default>

c0000283
00:10:43.100 --> 00:10:44.100 line:90% align:center
<Default><b>The fate of this planet</b></Default>

c0000284
00:10:44.190 --> 00:10:46.060 line:90% align:center
<Default><b>brought us
a most remarkable guest.</b></Default>

c0000285
00:10:46.650 --> 00:10:47.650 line:90% align:center
<Default><b>[ON]
You see.</b></Default>

c0000286
00:10:48.650 --> 00:10:49.650 line:90% align:center
<Default><b>[chuckles softly]</b></Default>

c0000287
00:10:51.030 --> 00:10:52.150 line:90% align:center
<Default><b>How'd she...?</b></Default>

c0000288
00:10:52.240 --> 00:10:54.030 line:90% align:center
<Default><b>[RISYA]
Close, but no dice!</b></Default>

c0000289
00:10:54.570 --> 00:10:56.410 line:90% align:center
<Default><b>So much for being
a model gentleman.</b></Default>

c0000290
00:10:56.490 --> 00:10:57.320 line:90% align:center
<Default><b>Now.</b></Default>

c0000291
00:10:57.410 --> 00:10:58.530 line:90% align:center
<Default><b>Does an Imperial solider</b></Default>

c0000292
00:10:58.620 --> 00:11:00.490 line:90% align:center
<Default><b>by the name of Mismis
ring any bells?</b></Default>

c0000293
00:11:00.910 --> 00:11:02.080 line:90% align:center
<Default><b>Mismis?</b></Default>

c0000294
00:11:02.160 --> 00:11:04.000 line:90% align:center
<Default><b>[RISYA] She's a captain
of the Imperial Army.</b></Default>

c0000295
00:11:04.500 --> 00:11:05.920 line:90% align:center
<Default><b>You met her at Mudor Canyon,</b></Default>

c0000296
00:11:06.000 --> 00:11:08.840 line:90% align:center
<Default><b>where you allegedly sent her
on a nasty trip to the vortex.</b></Default>

c0000297
00:11:09.750 --> 00:11:10.710 line:90% align:center
<Default><b>Anything?</b></Default>

c0000298
00:11:10.800 --> 00:11:12.510 line:90% align:center
<Default><b>Because I've heard
stories about you.</b></Default>

c0000299
00:11:12.880 --> 00:11:14.970 line:90% align:center
<Default><b>Word gets around fast
in our cohort.</b></Default>

c0000300
00:11:15.840 --> 00:11:17.760 line:90% align:center
<Default><b>Oh.
Now that you mention it,</b></Default>

c0000301
00:11:18.220 --> 00:11:20.310 line:90% align:center
<Default><b>that girl does sound
vaguely familiar.</b></Default>

c0000302
00:11:20.850 --> 00:11:21.850 line:90% align:center
<Default><b>I see.</b></Default>

c0000303
00:11:22.310 --> 00:11:24.350 line:90% align:center
<Default><b>The two of you lot
share a connection, then.</b></Default>

c0000304
00:11:25.270 --> 00:11:26.440 line:90% align:center
<Default><b>How peculiar.</b></Default>

c0000305
00:11:26.520 --> 00:11:28.650 line:90% align:center
<Default><b>They recruited you
around the same time,</b></Default>

c0000306
00:11:28.730 --> 00:11:30.320 line:90% align:center
<Default><b>yet she is
at a captain's level,</b></Default>

c0000307
00:11:30.400 --> 00:11:32.780 line:90% align:center
<Default><b>while you were promoted
to Saint Disciple?</b></Default>

c0000308
00:11:32.860 --> 00:11:34.150 line:90% align:center
<Default><b>[RISYA]
Well, more or less.</b></Default>

c0000309
00:11:34.860 --> 00:11:36.280 line:90% align:center
<Default><b>[ON]
From what I hear,</b></Default>

c0000310
00:11:36.360 --> 00:11:38.700 line:90% align:center
<Default><b>the army is known to be
quite competitive</b></Default>

c0000311
00:11:38.780 --> 00:11:40.200 line:90% align:center
<Default><b>when it comes to rank.</b></Default>

c0000312
00:11:40.950 --> 00:11:43.500 line:90% align:center
<Default><b>Many must covet
the position you are in.</b></Default>

c0000313
00:11:43.580 --> 00:11:44.620 line:90% align:center
<Default><b>[RISYA]
Never gets old!</b></Default>

c0000314
00:11:45.500 --> 00:11:48.380 line:90% align:center
<Default><b>Unlike turning 22
for the fourth time counting.</b></Default>

c0000315
00:11:49.130 --> 00:11:50.340 line:90% align:center
<Default><b>Four times counting?</b></Default>

c0000316
00:11:51.170 --> 00:11:53.050 line:90% align:center
<Default><b>You're full of surprises,
young lady.</b></Default>

c0000317
00:11:53.670 --> 00:11:56.130 line:90% align:center
<Default><b>Or is it more apt
to call you an old vet?</b></Default>

c0000318
00:11:56.930 --> 00:11:58.890 line:90% align:center
<Default><b>Pardon!
I'm not that old!</b></Default>

c0000319
00:11:59.680 --> 00:12:03.060 line:90% align:center
<Default><b>It is my personal policy
to start over before I hit 30!</b></Default>

c0000320
00:12:03.520 --> 00:12:04.680 line:90% align:center
<Default><b>You're looking at...</b></Default>

c0000321
00:12:04.770 --> 00:12:06.980 line:90% align:center
<Default><b>a young,
lovely woman in her prime!</b></Default>

c0000322
00:12:07.060 --> 00:12:08.440 line:90% align:center
<Default><b>-[laughs]
-[ON] Hmm.</b></Default>

c0000323
00:12:08.980 --> 00:12:10.940 line:90% align:center
<Default><b>[RISYA] Anyway.
Enough chit-chat.</b></Default>

c0000324
00:12:11.690 --> 00:12:12.860 line:90% align:center
<Default><b>The Apostles passed down</b></Default>

c0000325
00:12:12.940 --> 00:12:14.900 line:90% align:center
<Default><b>a to list of purebreds
to capture.</b></Default>

c0000326
00:12:15.240 --> 00:12:17.570 line:90% align:center
<Default><b>-[On chokes]
-Think I'll start with you.</b></Default>

c0000327
00:12:18.610 --> 00:12:20.780 line:90% align:center
<Default><b>An Imperial with an astral art?</b></Default>

c0000328
00:12:22.450 --> 00:12:23.580 line:90% align:center
<Default><b>[GROWLEY]
Here.</b></Default>

c0000329
00:12:23.660 --> 00:12:26.330 line:90% align:center
<Default><b>Allow me to measure
the depth of your sin.</b></Default>

c0000330
00:12:27.040 --> 00:12:28.710 line:90% align:center
<Default><b>♪</b></Default>

c0000331
00:12:30.040 --> 00:12:32.380 line:90% align:center
<Default><b>[NAMELESS]
An embodiment of astral energy?</b></Default>

c0000332
00:12:32.710 --> 00:12:34.960 line:90% align:center
<Default><b>[GROWLEY]
An avatar, to be precise.</b></Default>

c0000333
00:12:35.050 --> 00:12:37.130 line:90% align:center
<Default><b>You have committed a sin,
and thus,</b></Default>

c0000334
00:12:37.220 --> 00:12:38.380 line:90% align:center
<Default><b>heavy on your shoulders,</b></Default>

c0000335
00:12:38.470 --> 00:12:40.970 line:90% align:center
<Default><b>that sin has become
your punishment to bear.</b></Default>

c0000336
00:12:41.600 --> 00:12:42.720 line:90% align:center
<Default><b>Your folly is believing</b></Default>

c0000337
00:12:42.800 --> 00:12:45.390 line:90% align:center
<Default><b>you could carelessly attack me
without retaliation.</b></Default>

c0000338
00:12:45.470 --> 00:12:46.480 line:90% align:center
<Default><b>[knife clatters]</b></Default>

c0000339
00:12:47.310 --> 00:12:49.350 line:90% align:center
<Default><b>How did this confidence
develop?</b></Default>

c0000340
00:12:49.440 --> 00:12:50.480 line:90% align:center
<Default><b>Did you truly believe</b></Default>

c0000341
00:12:50.560 --> 00:12:52.770 line:90% align:center
<Default><b>you could tip
the scales of judgement?</b></Default>

c0000342
00:12:52.860 --> 00:12:53.860 line:90% align:center
<Default><b>[NAMELESS]
Judgement?</b></Default>

c0000343
00:12:55.030 --> 00:12:57.400 line:90% align:center
<Default><b>I was never one
to beg for forgiveness.</b></Default>

c0000344
00:12:58.450 --> 00:12:59.450 line:90% align:center
<Default><b>Tedious.</b></Default>

c0000345
00:13:00.200 --> 00:13:01.950 line:90% align:center
<Default><b>[Growley laughs]</b></Default>

c0000346
00:13:03.410 --> 00:13:04.580 line:90% align:center
<Default><b>[NAMELESS]
Pesky thing.</b></Default>

c0000347
00:13:04.660 --> 00:13:05.830 line:90% align:center
<Default><b>♪</b></Default>

c0000348
00:13:05.910 --> 00:13:07.960 line:90% align:center
<Default><b>[explodes]</b></Default>

c0000349
00:13:08.040 --> 00:13:09.160 line:90% align:center
<Default><b>[shatters]</b></Default>

c0000350
00:13:09.250 --> 00:13:10.870 line:90% align:center
<Default><b>[GROWLEY]
It's useless!</b></Default>

c0000351
00:13:10.960 --> 00:13:12.840 line:90% align:center
<Default><b>What good is a blade or boulder</b></Default>

c0000352
00:13:12.920 --> 00:13:15.800 line:90% align:center
<Default><b>to a being that
cannot be punctured or crushed?</b></Default>

c0000353
00:13:15.880 --> 00:13:18.340 line:90% align:center
<Default><b>[NAMELESS] A counterattack-type
astral spirit?</b></Default>

c0000354
00:13:18.670 --> 00:13:21.970 line:90% align:center
<Default><b>Astral energy grows in response
to the enemy's abilities.</b></Default>

c0000355
00:13:22.640 --> 00:13:25.140 line:90% align:center
<Default><b>Gorging until it reaches
a certain point,</b></Default>

c0000356
00:13:25.220 --> 00:13:27.600 line:90% align:center
<Default><b>before taking the form
of a beast to attack.</b></Default>

c0000357
00:13:28.600 --> 00:13:29.770 line:90% align:center
<Default><b>But that can't be all.</b></Default>

c0000358
00:13:30.190 --> 00:13:33.110 line:90% align:center
<Default><b>Several other factors
must influence its growth.</b></Default>

c0000359
00:13:33.190 --> 00:13:34.820 line:90% align:center
<Default><b>Your injuries, for example.</b></Default>

c0000360
00:13:35.360 --> 00:13:37.690 line:90% align:center
<Default><b>And another related
to your opponent's condition.</b></Default>

c0000361
00:13:38.570 --> 00:13:39.950 line:90% align:center
<Default><b>Or more accurately,</b></Default>

c0000362
00:13:40.030 --> 00:13:40.950 line:90% align:center
<Default><b>their "sin."</b></Default>

c0000363
00:13:41.030 --> 00:13:42.280 line:90% align:center
<Default><b>[Growley chuckles]</b></Default>

c0000364
00:13:42.360 --> 00:13:44.830 line:90% align:center
<Default><b>[GROWLEY] So, the Imperial dog
catches on quick!</b></Default>

c0000365
00:13:45.660 --> 00:13:46.990 line:90% align:center
<Default><b>I suppose I should reward you</b></Default>

c0000366
00:13:47.080 --> 00:13:48.620 line:90% align:center
<Default><b>with a warning
about the avatar,</b></Default>

c0000367
00:13:48.700 --> 00:13:50.120 line:90% align:center
<Default><b>so listen closely.</b></Default>

c0000368
00:13:50.210 --> 00:13:52.210 line:90% align:center
<Default><b>Its appetite is endless.</b></Default>

c0000369
00:13:52.620 --> 00:13:53.830 line:90% align:center
<Default><b>[NAMELESS]
Ugly creature.</b></Default>

c0000370
00:13:54.920 --> 00:13:57.050 line:90% align:center
<Default><b>Its ability to go through
physical objects</b></Default>

c0000371
00:13:57.130 --> 00:13:58.420 line:90% align:center
<Default><b>will be the death of you.</b></Default>

c0000372
00:14:02.680 --> 00:14:03.680 line:90% align:center
<Default><b>[Growley chuckles]</b></Default>

c0000373
00:14:09.520 --> 00:14:12.060 line:90% align:center
<Default><b>[NAMELESS] Die with your
greedy astral spirit.</b></Default>

c0000374
00:14:12.140 --> 00:14:13.310 line:90% align:center
<Default><b>Demon.</b></Default>

c0000375
00:14:14.610 --> 00:14:15.610 line:90% align:center
<Default><b>[car accelerates]</b></Default>

c0000376
00:14:15.690 --> 00:14:17.070 line:90% align:center
<Default><b>[tires screeching]</b></Default>

c0000377
00:14:17.150 --> 00:14:18.150 line:90% align:center
<Default><b>[explodes]</b></Default>

c0000378
00:14:18.860 --> 00:14:21.610 line:90% align:center
<Default><b>Of course. Using the shadows
to ambush us!</b></Default>

c0000379
00:14:21.950 --> 00:14:22.950 line:90% align:center
<Default><b>[ice shatters]</b></Default>

c0000380
00:14:23.780 --> 00:14:24.780 line:90% align:center
<Default><b>[Alice gasps]</b></Default>

c0000381
00:14:25.740 --> 00:14:27.080 line:90% align:center
<Default><b>Why is this happening?</b></Default>

c0000382
00:14:27.160 --> 00:14:28.700 line:90% align:center
<Default><b>Stop!
Lady Alice!</b></Default>

c0000383
00:14:28.790 --> 00:14:31.040 line:90% align:center
<Default><b>Enemies could be
lurking around any corner.</b></Default>

c0000384
00:14:31.750 --> 00:14:32.960 line:90% align:center
<Default><b>-Stay alert.
-Hm.</b></Default>

c0000385
00:14:33.500 --> 00:14:34.630 line:90% align:center
<Default><b>[MAGE]
Lady Alice!</b></Default>

c0000386
00:14:34.710 --> 00:14:36.000 line:90% align:center
<Default><b>I'm glad you're safe!</b></Default>

c0000387
00:14:36.080 --> 00:14:37.090 line:90% align:center
<Default><b>You two!</b></Default>

c0000388
00:14:37.170 --> 00:14:38.590 line:90% align:center
<Default><b>Give me your report.
Now!</b></Default>

c0000389
00:14:39.090 --> 00:14:40.130 line:90% align:center
<Default><b>Right!</b></Default>

c0000390
00:14:40.210 --> 00:14:42.510 line:90% align:center
<Default><b>Securing the royal palace
is our top priority.</b></Default>

c0000391
00:14:43.300 --> 00:14:45.340 line:90% align:center
<Default><b>Please go to the queen,
My Lady Alice!</b></Default>

c0000392
00:14:45.800 --> 00:14:46.970 line:90% align:center
<Default><b>Protect her from harm!</b></Default>

c0000393
00:14:47.970 --> 00:14:49.180 line:90% align:center
<Default><b>We'll deal with all the fires!</b></Default>

c0000394
00:14:49.260 --> 00:14:50.270 line:90% align:center
<Default><b>[Alice gasps]</b></Default>

c0000395
00:14:50.640 --> 00:14:52.140 line:90% align:center
<Default><b>[ALICE]
No, get back!</b></Default>

c0000396
00:14:53.390 --> 00:14:54.980 line:90% align:center
<Default><b>[both groaning]</b></Default>

c0000397
00:14:55.060 --> 00:14:56.060 line:90% align:center
<Default><b>[both groan]</b></Default>

c0000398
00:14:56.150 --> 00:14:56.980 line:90% align:center
<Default><b>[thuds]</b></Default>

c0000399
00:14:57.060 --> 00:14:58.070 line:90% align:center
<Default><b>Are you all right?</b></Default>

c0000400
00:14:58.400 --> 00:15:00.150 line:90% align:center
<Default><b>Rin.
Call a medic now.</b></Default>

c0000401
00:15:00.230 --> 00:15:01.530 line:90% align:center
<Default><b>-Quickly!
-Right!</b></Default>

c0000402
00:15:01.610 --> 00:15:04.150 line:90% align:center
<Default><b>[fire crackling]</b></Default>

c0000403
00:15:04.240 --> 00:15:07.240 line:90% align:center
<Default><b>♪</b></Default>

c0000404
00:15:07.950 --> 00:15:09.620 line:90% align:center
<Default><b>[ALICE] Do me a favor
and evacuate everyone</b></Default>

c0000405
00:15:09.700 --> 00:15:10.620 line:90% align:center
<Default><b>to the shelter.</b></Default>

c0000406
00:15:10.700 --> 00:15:12.410 line:90% align:center
<Default><b>Personnel should be
waiting for them there.</b></Default>

c0000407
00:15:14.080 --> 00:15:15.420 line:90% align:center
<Default><b>I'll handle things here.</b></Default>

c0000408
00:15:15.870 --> 00:15:17.380 line:90% align:center
<Default><b>Wait, think about this!</b></Default>

c0000409
00:15:18.000 --> 00:15:19.130 line:90% align:center
<Default><b>Stay calm!</b></Default>

c0000410
00:15:19.880 --> 00:15:21.260 line:90% align:center
<Default><b>Yes, I already have.</b></Default>

c0000411
00:15:22.130 --> 00:15:23.760 line:90% align:center
<Default><b>And I am perfectly calm.</b></Default>

c0000412
00:15:24.840 --> 00:15:26.430 line:90% align:center
<Default><b>The castle should be
well defended.</b></Default>

c0000413
00:15:27.640 --> 00:15:28.550 line:90% align:center
<Default><b>But the people here are</b></Default>

c0000414
00:15:28.640 --> 00:15:30.260 line:90% align:center
<Default><b>bearing the brunt
of the attack.</b></Default>

c0000415
00:15:31.270 --> 00:15:32.270 line:90% align:center
<Default><b>Uh.</b></Default>

c0000416
00:15:32.350 --> 00:15:33.350 line:90% align:center
<Default><b>[inhales deeply]</b></Default>

c0000417
00:15:33.930 --> 00:15:34.940 line:90% align:center
<Default><b>[exhales]</b></Default>

c0000418
00:15:35.640 --> 00:15:37.350 line:90% align:center
<Default><b>Return to me
in one quarter-hour.</b></Default>

c0000419
00:15:37.900 --> 00:15:39.730 line:90% align:center
<Default><b>I'll take control of the fires.</b></Default>

c0000420
00:15:40.190 --> 00:15:41.190 line:90% align:center
<Default><b>Yes!</b></Default>

c0000421
00:15:41.610 --> 00:15:42.610 line:90% align:center
<Default><b>As you wish!</b></Default>

c0000422
00:15:43.400 --> 00:15:46.410 line:90% align:center
<Default><b>[stomping]</b></Default>

c0000423
00:15:47.820 --> 00:15:49.910 line:90% align:center
<Default><b>And if I'm so much
as a second late,</b></Default>

c0000424
00:15:49.990 --> 00:15:51.080 line:90% align:center
<Default><b>do not delay!</b></Default>

c0000425
00:15:51.160 --> 00:15:52.870 line:90% align:center
<Default><b>Head for the queen without me!</b></Default>

c0000426
00:15:52.950 --> 00:15:54.370 line:90% align:center
<Default><b>[footsteps receding]</b></Default>

c0000427
00:15:54.710 --> 00:15:55.710 line:90% align:center
<Default><b>[ALICE]
It's fine.</b></Default>

c0000428
00:15:56.580 --> 00:15:58.330 line:90% align:center
<Default><b>I know I made
the right decision.</b></Default>

c0000429
00:15:59.380 --> 00:16:01.000 line:90% align:center
<Default><b>Not even a Saint Disciple</b></Default>

c0000430
00:16:01.090 --> 00:16:02.710 line:90% align:center
<Default><b>could infiltrate
the queen's palace</b></Default>

c0000431
00:16:02.800 --> 00:16:04.130 line:90% align:center
<Default><b>in such a short amount of time.</b></Default>

c0000432
00:16:05.300 --> 00:16:07.130 line:90% align:center
<Default><b>All forces!
Fall back!</b></Default>

c0000433
00:16:07.590 --> 00:16:09.010 line:90% align:center
<Default><b>Take cover behind me!</b></Default>

c0000434
00:16:09.090 --> 00:16:10.260 line:90% align:center
<Default><b>Right now!</b></Default>

c0000435
00:16:10.350 --> 00:16:12.470 line:90% align:center
<Default><b>I'll put out these flames
in one fell swoop!</b></Default>

c0000436
00:16:15.230 --> 00:16:16.390 line:90% align:center
<Default><b>[ELLETEAR]
Target the fuel tanks</b></Default>

c0000437
00:16:16.480 --> 00:16:19.520 line:90% align:center
<Default><b>in the quarantine warehouse
to set the assault in motion.</b></Default>

c0000438
00:16:20.190 --> 00:16:22.070 line:90% align:center
<Default><b>The blaze easily overwhelms.</b></Default>

c0000439
00:16:22.440 --> 00:16:24.110 line:90% align:center
<Default><b>Even the palace's elite
would have trouble</b></Default>

c0000440
00:16:24.190 --> 00:16:25.530 line:90% align:center
<Default><b>controlling the inferno.</b></Default>

c0000441
00:16:27.280 --> 00:16:28.740 line:90% align:center
<Default><b>Tonight's dramatic performance</b></Default>

c0000442
00:16:28.820 --> 00:16:30.320 line:90% align:center
<Default><b>couldn't have played out
any better.</b></Default>

c0000443
00:16:31.280 --> 00:16:32.700 line:90% align:center
<Default><b>[knocking on door]</b></Default>

c0000444
00:16:33.240 --> 00:16:34.410 line:90% align:center
<Default><b>[MINISTER]
Lady Elletear,</b></Default>

c0000445
00:16:34.490 --> 00:16:35.620 line:90% align:center
<Default><b>it's the Imperials!</b></Default>

c0000446
00:16:36.210 --> 00:16:38.250 line:90% align:center
<Default><b>[ELLETEAR] I wonder
how Lord Talisman is doing.</b></Default>

c0000447
00:16:38.750 --> 00:16:41.170 line:90% align:center
<Default><b>I imagine he's captured Sisbell
right about now.</b></Default>

c0000448
00:16:42.210 --> 00:16:43.210 line:90% align:center
<Default><b>[MINISTER]
Do you hear me?</b></Default>

c0000449
00:16:43.670 --> 00:16:44.800 line:90% align:center
<Default><b>[ELLETEAR]
Minister.</b></Default>

c0000450
00:16:44.880 --> 00:16:45.960 line:90% align:center
<Default><b>[MINISTER]
Oh, thank goodness!</b></Default>

c0000451
00:16:46.050 --> 00:16:47.050 line:90% align:center
<Default><b>We must leave!</b></Default>

c0000452
00:16:47.670 --> 00:16:48.930 line:90% align:center
<Default><b>[ELLETEAR]
You needn't worry.</b></Default>

c0000453
00:16:50.050 --> 00:16:51.050 line:90% align:center
<Default><b>[MINISTER]
Huh?</b></Default>

c0000454
00:16:51.470 --> 00:16:53.810 line:90% align:center
<Default><b>[ELLETEAR] Please, evacuate
to the shelter without me.</b></Default>

c0000455
00:16:54.520 --> 00:16:56.980 line:90% align:center
<Default><b>As long as you stay away
from the queen's palace,</b></Default>

c0000456
00:16:57.060 --> 00:16:58.350 line:90% align:center
<Default><b>you'll be safe from harm.</b></Default>

c0000457
00:16:59.270 --> 00:17:01.940 line:90% align:center
<Default><b>The army has no need
to injure bystanders.</b></Default>

c0000458
00:17:02.690 --> 00:17:04.440 line:90% align:center
<Default><b>[MINISTER]
And what of you, Lady Elletear?</b></Default>

c0000459
00:17:05.070 --> 00:17:06.240 line:90% align:center
<Default><b>[ELLETEAR]
Give me a moment.</b></Default>

c0000460
00:17:06.320 --> 00:17:07.820 line:90% align:center
<Default><b>I will meet you there shortly.</b></Default>

c0000461
00:17:09.360 --> 00:17:10.360 line:90% align:center
<Default><b>[chuckles softly]</b></Default>

c0000462
00:17:11.110 --> 00:17:12.160 line:90% align:center
<Default><b>[MINISTER]
As you wish.</b></Default>

c0000463
00:17:12.240 --> 00:17:13.580 line:90% align:center
<Default><b>But please hurry.</b></Default>

c0000464
00:17:13.660 --> 00:17:15.200 line:90% align:center
<Default><b>Leave as soon as you can!</b></Default>

c0000465
00:17:15.290 --> 00:17:17.700 line:90% align:center
<Default><b>[footsteps receding]</b></Default>

c0000466
00:17:18.120 --> 00:17:19.460 line:90% align:center
<Default><b>Leave?
No,</b></Default>

c0000467
00:17:19.540 --> 00:17:21.120 line:90% align:center
<Default><b>the stage has
only just been set,</b></Default>

c0000468
00:17:21.210 --> 00:17:22.920 line:90% align:center
<Default><b>and the Disciples are up next.</b></Default>

c0000469
00:17:23.340 --> 00:17:26.050 line:90% align:center
<Default><b>Excessive injuries to
the public aren't my ideal.</b></Default>

c0000470
00:17:26.460 --> 00:17:28.800 line:90% align:center
<Default><b>I'd rather they get rid
of the queen without fuss.</b></Default>

c0000471
00:17:30.470 --> 00:17:31.930 line:90% align:center
<Default><b>Enough time's passed.</b></Default>

c0000472
00:17:32.010 --> 00:17:34.100 line:90% align:center
<Default><b>I really should be
getting ready myself.</b></Default>

c0000473
00:17:35.220 --> 00:17:36.970 line:90% align:center
<Default><b>Alice. Sisbell.</b></Default>

c0000474
00:17:37.430 --> 00:17:38.390 line:90% align:center
<Default><b>Mother.</b></Default>

c0000475
00:17:38.890 --> 00:17:41.560 line:90% align:center
<Default><b>Too long you've turned
a blind eye to my pain.</b></Default>

c0000476
00:17:43.270 --> 00:17:44.770 line:90% align:center
<Default><b>That all changes tonight.</b></Default>

c0000477
00:17:45.270 --> 00:17:48.150 line:90% align:center
<Default><b>Witness with your own eyes
Sovereignty's cleansing.</b></Default>

c0000478
00:17:48.240 --> 00:17:49.530 line:90% align:center
<Default><b>[JOHAIM]
Queen Nebulis.</b></Default>

c0000479
00:17:50.110 --> 00:17:51.950 line:90% align:center
<Default><b>I'm not here
to waste your time,</b></Default>

c0000480
00:17:52.450 --> 00:17:53.910 line:90% align:center
<Default><b>so I'll keep this short.</b></Default>

c0000481
00:17:53.990 --> 00:17:56.700 line:90% align:center
<Default><b>-[gasps]
-I'm here to take your head.</b></Default>

c0000482
00:17:56.790 --> 00:17:58.200 line:90% align:center
<Default><b>On your knees!</b></Default>

c0000483
00:17:59.450 --> 00:18:00.540 line:90% align:center
<Default><b>[Johaim grunts]</b></Default>

c0000484
00:18:01.330 --> 00:18:02.620 line:90% align:center
<Default><b>[debris clatters]</b></Default>

c0000485
00:18:04.250 --> 00:18:06.380 line:90% align:center
<Default><b>[JOHAIM]
The Serene Wind, Milla.</b></Default>

c0000486
00:18:06.460 --> 00:18:09.550 line:90% align:center
<Default><b>And yet, your astral art
is as violent as they come.</b></Default>

c0000487
00:18:10.880 --> 00:18:11.930 line:90% align:center
<Default><b>[MILLAVAIR]
Hearing a decades-old</b></Default>

c0000488
00:18:12.010 --> 00:18:13.590 line:90% align:center
<Default><b>moniker feels strange.</b></Default>

c0000489
00:18:13.970 --> 00:18:16.850 line:90% align:center
<Default><b>[JOHAIM]
Millavair Lou Nebulis VIII.</b></Default>

c0000490
00:18:16.930 --> 00:18:19.730 line:90% align:center
<Default><b>An astral mage
who harnesses wind.</b></Default>

c0000491
00:18:19.810 --> 00:18:21.440 line:90% align:center
<Default><b>Or maybe
I should be more accurate.</b></Default>

c0000492
00:18:22.190 --> 00:18:24.230 line:90% align:center
<Default><b>You have mastery of air itself.</b></Default>

c0000493
00:18:24.310 --> 00:18:27.190 line:90% align:center
<Default><b>That, on a much larger scale,
prevails over wind.</b></Default>

c0000494
00:18:27.730 --> 00:18:30.150 line:90% align:center
<Default><b>You were 11 years old
when you entered the war.</b></Default>

c0000495
00:18:30.240 --> 00:18:31.400 line:90% align:center
<Default><b>In the ten years after,</b></Default>

c0000496
00:18:31.490 --> 00:18:33.280 line:90% align:center
<Default><b>you fought
and conquered more battles</b></Default>

c0000497
00:18:33.360 --> 00:18:34.740 line:90% align:center
<Default><b>than any other pure-blood,</b></Default>

c0000498
00:18:34.820 --> 00:18:36.280 line:90% align:center
<Default><b>acquiring around 3%</b></Default>

c0000499
00:18:36.370 --> 00:18:38.290 line:90% align:center
<Default><b>of the Empire's
total territory.</b></Default>

c0000500
00:18:38.370 --> 00:18:40.500 line:90% align:center
<Default><b>Despite being a witch,
you rose in the ranks</b></Default>

c0000501
00:18:40.580 --> 00:18:41.580 line:90% align:center
<Default><b>to become Sovereignty's</b></Default>

c0000502
00:18:41.660 --> 00:18:43.920 line:90% align:center
<Default><b>most skilled martial artist
and assassin.</b></Default>

c0000503
00:18:44.000 --> 00:18:46.380 line:90% align:center
<Default><b>Many considered you
the most powerful candidate</b></Default>

c0000504
00:18:46.460 --> 00:18:47.920 line:90% align:center
<Default><b>for queen in history.</b></Default>

c0000505
00:18:48.340 --> 00:18:50.550 line:90% align:center
<Default><b>But, you've grown weaker.</b></Default>

c0000506
00:18:51.470 --> 00:18:53.510 line:90% align:center
<Default><b>[MILLAVAIR] To stand
and speak with such surety,</b></Default>

c0000507
00:18:53.590 --> 00:18:54.680 line:90% align:center
<Default><b>one would think you'd witnessed</b></Default>

c0000508
00:18:54.760 --> 00:18:56.800 line:90% align:center
<Default><b>my accomplishments
for yourself.</b></Default>

c0000509
00:18:56.890 --> 00:18:58.180 line:90% align:center
<Default><b>[JOHAIM]
Let's just say,</b></Default>

c0000510
00:18:58.260 --> 00:19:00.680 line:90% align:center
<Default><b>word around the palace spreads.</b></Default>

c0000511
00:19:00.770 --> 00:19:01.770 line:90% align:center
<Default><b>[MILLAVAIR]
I see.</b></Default>

c0000512
00:19:02.770 --> 00:19:03.810 line:90% align:center
<Default><b>[MILLAVAIR]
Where are the guards?</b></Default>

c0000513
00:19:04.560 --> 00:19:05.850 line:90% align:center
<Default><b>What's taking them so long?</b></Default>

c0000514
00:19:06.230 --> 00:19:07.520 line:90% align:center
<Default><b>The ones nearby
should have noticed</b></Default>

c0000515
00:19:07.610 --> 00:19:08.690 line:90% align:center
<Default><b>the commotion by now.</b></Default>

c0000516
00:19:09.360 --> 00:19:10.860 line:90% align:center
<Default><b>One must make sacrifices.</b></Default>

c0000517
00:19:11.650 --> 00:19:13.240 line:90% align:center
<Default><b>The state of my power
is irrelevant</b></Default>

c0000518
00:19:13.320 --> 00:19:15.030 line:90% align:center
<Default><b>when balanced
against the alternative.</b></Default>

c0000519
00:19:16.240 --> 00:19:18.410 line:90% align:center
<Default><b>Have other Saint Disciples
infiltrated the palace</b></Default>

c0000520
00:19:18.490 --> 00:19:19.580 line:90% align:center
<Default><b>and engaged the guards?</b></Default>

c0000521
00:19:20.240 --> 00:19:21.950 line:90% align:center
<Default><b>So long as I can protect
my nation</b></Default>

c0000522
00:19:22.040 --> 00:19:23.290 line:90% align:center
<Default><b>with the power I do have,</b></Default>

c0000523
00:19:23.370 --> 00:19:24.960 line:90% align:center
<Default><b>what difference does it make?</b></Default>

c0000524
00:19:26.040 --> 00:19:28.090 line:90% align:center
<Default><b>[MILLAVAIR] Alice should have
been here by now.</b></Default>

c0000525
00:19:28.750 --> 00:19:30.960 line:90% align:center
<Default><b>[JOHAIM] Are you waiting for
the Ice Calamity Witch?</b></Default>

c0000526
00:19:33.340 --> 00:19:34.470 line:90% align:center
<Default><b>[sword clanking]</b></Default>

c0000527
00:19:35.550 --> 00:19:37.470 line:90% align:center
<Default><b>[MILLAVAIR]
Bomb Cyclone!</b></Default>

c0000528
00:19:38.640 --> 00:19:40.260 line:90% align:center
<Default><b>There must be a conspirator.</b></Default>

c0000529
00:19:40.350 --> 00:19:42.390 line:90% align:center
<Default><b>[JOHAIM]
This is an information war.</b></Default>

c0000530
00:19:42.470 --> 00:19:45.350 line:90% align:center
<Default><b>Sheer offense alone isn't
nearly enough to kill you.</b></Default>

c0000531
00:19:45.770 --> 00:19:47.270 line:90% align:center
<Default><b>I was right about Elletear.</b></Default>

c0000532
00:19:47.810 --> 00:19:48.810 line:90% align:center
<Default><b>[grunts]</b></Default>

c0000533
00:19:49.770 --> 00:19:50.610 line:90% align:center
<Default><b>You're dead.</b></Default>

c0000534
00:19:50.690 --> 00:19:53.280 line:90% align:center
<Default><b>[MILLAVAIR] You dare
underestimate a queen?</b></Default>

c0000535
00:19:53.360 --> 00:19:55.110 line:90% align:center
<Default><b>[groans]</b></Default>

c0000536
00:19:55.200 --> 00:19:56.860 line:90% align:center
<Default><b>I suppose I have no choice.</b></Default>

c0000537
00:19:57.200 --> 00:19:59.030 line:90% align:center
<Default><b>If neither the guards
nor Alice will come,</b></Default>

c0000538
00:19:59.120 --> 00:20:00.490 line:90% align:center
<Default><b>I will manage without them.</b></Default>

c0000539
00:20:00.950 --> 00:20:03.750 line:90% align:center
<Default><b>Though, I do loathe the idea
of making a mess of the Hall.</b></Default>

c0000540
00:20:04.370 --> 00:20:06.330 line:90% align:center
<Default><b>It's already seen
enough destruction.</b></Default>

c0000541
00:20:07.580 --> 00:20:08.580 line:90% align:center
<Default><b>Either way.</b></Default>

c0000542
00:20:09.130 --> 00:20:11.300 line:90% align:center
<Default><b>This farce has run its course.</b></Default>

c0000543
00:20:12.590 --> 00:20:14.630 line:90% align:center
<Default><b>[TALISMAN]
This nation has been worn down</b></Default>

c0000544
00:20:14.720 --> 00:20:16.930 line:90% align:center
<Default><b>by the ravages of time.</b></Default>

c0000545
00:20:17.010 --> 00:20:17.970 line:90% align:center
<Default><b>As it stands,</b></Default>

c0000546
00:20:18.050 --> 00:20:20.260 line:90% align:center
<Default><b>the Lous and current queen
hold balance</b></Default>

c0000547
00:20:20.350 --> 00:20:21.930 line:90% align:center
<Default><b>in the war against the Empire.</b></Default>

c0000548
00:20:22.430 --> 00:20:26.190 line:90% align:center
<Default><b>And the Zoas continue to scream
for revenge against the Empire.</b></Default>

c0000549
00:20:26.520 --> 00:20:27.980 line:90% align:center
<Default><b>As for the Hydras,</b></Default>

c0000550
00:20:28.310 --> 00:20:30.690 line:90% align:center
<Default><b>we're dissatisfied with
the current state of affairs.</b></Default>

c0000551
00:20:31.770 --> 00:20:32.820 line:90% align:center
<Default><b>What do you think,</b></Default>

c0000552
00:20:33.280 --> 00:20:34.530 line:90% align:center
<Default><b>-Imperial?
-[Iska gasps]</b></Default>

c0000553
00:20:34.610 --> 00:20:35.820 line:90% align:center
<Default><b>[chuckles]</b></Default>

c0000554
00:20:35.900 --> 00:20:38.240 line:90% align:center
<Default><b>[ISKA] Is this really
just a wave astral art?</b></Default>

c0000555
00:20:39.530 --> 00:20:41.910 line:90% align:center
<Default><b>I'm impressed you saw
through that, soldier.</b></Default>

c0000556
00:20:43.990 --> 00:20:45.700 line:90% align:center
<Default><b>Sharp eyes you have on you!</b></Default>

c0000557
00:20:46.160 --> 00:20:49.120 line:90% align:center
<Default><b>Or perhaps you heard
and felt the churning?</b></Default>

c0000558
00:20:49.580 --> 00:20:50.880 line:90% align:center
<Default><b>[ISKA]
Take your pick!</b></Default>

c0000559
00:20:50.960 --> 00:20:52.750 line:90% align:center
<Default><b>♪</b></Default>

c0000560
00:20:52.840 --> 00:20:53.960 line:90% align:center
<Default><b>Uh.</b></Default>

c0000561
00:20:54.050 --> 00:20:55.050 line:90% align:center
<Default><b>[grunts]</b></Default>

c0000562
00:20:55.130 --> 00:20:57.090 line:90% align:center
<Default><b>[explodes]</b></Default>

c0000563
00:20:57.420 --> 00:20:58.430 line:90% align:center
<Default><b>[Iska groans]</b></Default>

c0000564
00:20:58.840 --> 00:21:00.390 line:90% align:center
<Default><b>[ISKA]
All that from one fist?</b></Default>

c0000565
00:21:00.760 --> 00:21:02.890 line:90% align:center
<Default><b>This can't be the work
of a single wave!</b></Default>

c0000566
00:21:03.760 --> 00:21:05.470 line:90% align:center
<Default><b>Masterfully dodged.</b></Default>

c0000567
00:21:05.560 --> 00:21:08.890 line:90% align:center
<Default><b>Do they train you Imperials
to pick up everything?</b></Default>

c0000568
00:21:08.980 --> 00:21:09.980 line:90% align:center
<Default><b>Hmm.</b></Default>

c0000569
00:21:10.350 --> 00:21:11.520 line:90% align:center
<Default><b>What I don't understand</b></Default>

c0000570
00:21:11.610 --> 00:21:13.320 line:90% align:center
<Default><b>is why you would
put your life on the line</b></Default>

c0000571
00:21:13.400 --> 00:21:15.110 line:90% align:center
<Default><b>to protect Lady Sisbell.</b></Default>

c0000572
00:21:15.900 --> 00:21:18.780 line:90% align:center
<Default><b>The reward she promised you
must be quite lucrative indeed.</b></Default>

c0000573
00:21:18.860 --> 00:21:21.530 line:90% align:center
<Default><b>Did you think we'd lay down
and let you overwhelm us?</b></Default>

c0000574
00:21:21.870 --> 00:21:24.490 line:90% align:center
<Default><b>If anything, you're the ones
who attacked us first.</b></Default>

c0000575
00:21:24.580 --> 00:21:26.790 line:90% align:center
<Default><b>For what it's worth,
you're quite misguided.</b></Default>

c0000576
00:21:27.450 --> 00:21:30.370 line:90% align:center
<Default><b>This is an estate owned
by the Sovereignty's royalty.</b></Default>

c0000577
00:21:30.460 --> 00:21:32.000 line:90% align:center
<Default><b>Soldiers from
the opposing nation</b></Default>

c0000578
00:21:32.080 --> 00:21:34.750 line:90% align:center
<Default><b>aren't the usual guests
that occupy this manor.</b></Default>

c0000579
00:21:35.090 --> 00:21:36.090 line:90% align:center
<Default><b>Elletear.</b></Default>

c0000580
00:21:36.460 --> 00:21:38.420 line:90% align:center
<Default><b>She told you everything,
didn't she?</b></Default>

c0000581
00:21:39.970 --> 00:21:42.050 line:90% align:center
<Default><b>Why would she turn her back
on her own mother?</b></Default>

c0000582
00:21:43.220 --> 00:21:45.680 line:90% align:center
<Default><b>Can one dare
put her beauty into words?</b></Default>

c0000583
00:21:46.060 --> 00:21:47.060 line:90% align:center
<Default><b>[ISKA]
What?</b></Default>

c0000584
00:21:47.560 --> 00:21:49.890 line:90% align:center
<Default><b>[TALISMAN] What the people
would deem "witchcraft,"</b></Default>

c0000585
00:21:49.980 --> 00:21:53.310 line:90% align:center
<Default><b>perfectly sums up the totality
of her exquisiteness.</b></Default>

c0000586
00:21:53.810 --> 00:21:56.190 line:90% align:center
<Default><b>Before her radiance,
even the Goddess herself</b></Default>

c0000587
00:21:56.280 --> 00:21:57.990 line:90% align:center
<Default><b>would bow and scrape.</b></Default>

c0000588
00:21:58.070 --> 00:22:01.030 line:90% align:center
<Default><b>Truly a magnificent gift
from the Gods.</b></Default>

c0000589
00:22:02.160 --> 00:22:03.160 line:90% align:center
<Default><b>And yet...</b></Default>

c0000590
00:22:03.240 --> 00:22:04.910 line:90% align:center
<Default><b>[shatters]</b></Default>

c0000591
00:22:05.370 --> 00:22:08.080 line:90% align:center
<Default><b>For all her elegance,
she was abandoned by the stars.</b></Default>

c0000592
00:22:08.160 --> 00:22:09.000 line:90% align:center
<Default><b>[Iska gasps]</b></Default>

c0000593
00:22:09.080 --> 00:22:10.870 line:90% align:center
<Default><b>Therein lies
your misunderstanding.</b></Default>

c0000594
00:22:11.330 --> 00:22:12.330 line:90% align:center
<Default><b>Despite what you think,</b></Default>

c0000595
00:22:12.420 --> 00:22:14.590 line:90% align:center
<Default><b>Hydra and Elletear's goals
are not the same.</b></Default>

c0000596
00:22:15.340 --> 00:22:18.010 line:90% align:center
<Default><b>We simply share
the same ideals and "step one."</b></Default>

c0000597
00:22:18.090 --> 00:22:20.510 line:90% align:center
<Default><b>Working together is
a matter of convenience.</b></Default>

c0000598
00:22:21.010 --> 00:22:23.090 line:90% align:center
<Default><b>And step one is
to overthrow the queen?</b></Default>

c0000599
00:22:23.430 --> 00:22:25.260 line:90% align:center
<Default><b>[TALISMAN] If we can
eliminate the current ruler,</b></Default>

c0000600
00:22:25.350 --> 00:22:27.140 line:90% align:center
<Default><b>Sovereignty's unshaken
foundation</b></Default>

c0000601
00:22:27.220 --> 00:22:28.560 line:90% align:center
<Default><b>will weaken ever so slightly.</b></Default>

c0000602
00:22:29.060 --> 00:22:30.100 line:90% align:center
<Default><b>Giving us the advantage</b></Default>

c0000603
00:22:30.180 --> 00:22:32.440 line:90% align:center
<Default><b>we'll sorely need
in our future endeavors.</b></Default>

c0000604
00:22:33.190 --> 00:22:35.900 line:90% align:center
<Default><b>So, is that what you told
the Empire to win them over?</b></Default>

c0000605
00:22:36.320 --> 00:22:38.530 line:90% align:center
<Default><b>I'll leave that answer
to your imagination.</b></Default>

c0000606
00:22:39.530 --> 00:22:41.610 line:90% align:center
<Default><b>Let's get one thing straight,
Talisman.</b></Default>

c0000607
00:22:43.820 --> 00:22:46.410 line:90% align:center
<Default><b>This isn't the battle
I want to fight with Nebulis.</b></Default>

c0000608
00:22:46.490 --> 00:22:47.910 line:90% align:center
<Default><b>Trust me on that.</b></Default>

c0000609
00:22:47.990 --> 00:22:49.410 line:90% align:center
<Default><b>Whatever do you mean?</b></Default>

c0000610
00:22:49.910 --> 00:22:52.460 line:90% align:center
<Default><b>What happens if we end up
doing things your way?</b></Default>

c0000611
00:22:53.460 --> 00:22:55.540 line:90% align:center
<Default><b>Both nations will
continue to hurt?</b></Default>

c0000612
00:22:55.630 --> 00:22:57.670 line:90% align:center
<Default><b>And any chance for peace
will be lost?</b></Default>

c0000613
00:22:57.750 --> 00:22:58.750 line:90% align:center
<Default><b>The end?</b></Default>

c0000614
00:22:59.250 --> 00:23:00.630 line:90% align:center
<Default><b>Well, I won't accept that.</b></Default>

c0000615
00:23:00.710 --> 00:23:03.090 line:90% align:center
<Default><b>That isn't the ending
I want for any of us!</b></Default>

c0000616
00:23:04.340 --> 00:23:06.010 line:90% align:center
<Default><b>I want my home to survive.</b></Default>

c0000617
00:23:06.090 --> 00:23:07.470 line:90% align:center
<Default><b>Same for Sovereignty!</b></Default>

c0000618
00:23:08.100 --> 00:23:09.810 line:90% align:center
<Default><b>Why does one have to fall?</b></Default>

c0000619
00:23:09.890 --> 00:23:11.890 line:90% align:center
<Default><b>A rousing speech, destroyer!
[clapping]</b></Default>

c0000620
00:23:11.980 --> 00:23:14.310 line:90% align:center
<Default><b>You're simply dripping
with romanticism.</b></Default>

c0000621
00:23:14.390 --> 00:23:16.150 line:90% align:center
<Default><b>A surprisingly sweet fantasy,</b></Default>

c0000622
00:23:16.230 --> 00:23:17.980 line:90% align:center
<Default><b>but you of all people</b></Default>

c0000623
00:23:18.070 --> 00:23:20.070 line:90% align:center
<Default><b>should know
that will never come to pass.</b></Default>

c0000624
00:23:20.150 --> 00:23:21.110 line:90% align:center
<Default><b>You see,</b></Default>

c0000625
00:23:21.190 --> 00:23:23.490 line:90% align:center
<Default><b>long has this day
been desired by both</b></Default>

c0000626
00:23:23.570 --> 00:23:25.610 line:90% align:center
<Default><b>Saint Disciples
and royals alike.</b></Default>

c0000627
00:23:25.700 --> 00:23:26.620 line:90% align:center
<Default><b>The ones who wished for</b></Default>

c0000628
00:23:26.700 --> 00:23:28.780 line:90% align:center
<Default><b>the nation's downfall,
at least.</b></Default>

c0000629
00:23:28.870 --> 00:23:30.330 line:90% align:center
<Default><b>What are you talking about?</b></Default>

c0000630
00:23:31.250 --> 00:23:32.830 line:90% align:center
<Default><b>They wanted to compare.</b></Default>

c0000631
00:23:34.040 --> 00:23:37.250 line:90% align:center
<Default><b>Find the elusive answer
to a decade-long question</b></Default>

c0000632
00:23:37.330 --> 00:23:40.340 line:90% align:center
<Default><b>of who is superior in
this crowded game of war.</b></Default>

c0000633
00:23:41.510 --> 00:23:43.800 line:90% align:center
<Default><b>The Saint Disciples
of the Empire...</b></Default>

c0000634
00:23:44.220 --> 00:23:46.970 line:90% align:center
<Default><b>or is it the purebred
descendants of the Founder?</b></Default>

c0000635
00:23:47.640 --> 00:23:49.510 line:90% align:center
<Default><b>All will know after today.</b></Default>

c0000636
00:23:49.600 --> 00:23:51.770 line:90% align:center
<Default><b>Once and for all,
who is champion.</b></Default>

c0000637
00:23:53.770 --> 00:23:54.770 line:90% align:center
<Default><b>Dear boy.</b></Default>

c0000638
00:23:55.980 --> 00:23:56.810 line:90% align:center
<Default><b>[snaps fingers]</b></Default>

c0000639
00:23:56.900 --> 00:23:58.940 line:90% align:center
<Default><b>That's what
this night is about.</b></Default>

