background-color: #00000000;
}

c0000000
00:00:00.960 --> 00:00:03.920 line:90% align:center
<Default><b>♪</b></Default>

c0000001
00:00:34.740 --> 00:00:36.080 line:90% align:center
<Default><b>[Talisman claps]</b></Default>

c0000002
00:00:36.540 --> 00:00:38.410 line:90% align:center
<Default><b>You're getting better
by the day, Mizzy.</b></Default>

c0000003
00:00:39.040 --> 00:00:40.420 line:90% align:center
<Default><b>I'm glad you think so.</b></Default>

c0000004
00:00:40.830 --> 00:00:42.500 line:90% align:center
<Default><b>Playing with you
is intimidating,</b></Default>

c0000005
00:00:42.630 --> 00:00:44.550 line:90% align:center
<Default><b>but I try my best
to please, Uncle.</b></Default>

c0000006
00:00:45.050 --> 00:00:47.550 line:90% align:center
<Default><b>Nonsense.
Our performance flourished</b></Default>

c0000007
00:00:47.710 --> 00:00:49.590 line:90% align:center
<Default><b>because you were there
to lead me along.</b></Default>

c0000008
00:00:50.090 --> 00:00:51.090 line:90% align:center
<Default><b>Come here.</b></Default>

c0000009
00:00:51.260 --> 00:00:52.260 line:90% align:center
<Default><b>[gasps]</b></Default>

c0000010
00:00:52.340 --> 00:00:53.350 line:90% align:center
<Default><b>[chuckles softly]</b></Default>

c0000011
00:00:58.770 --> 00:00:59.770 line:90% align:center
<Default><b>[MIZERHYBY]
Uncle?</b></Default>

c0000012
00:01:00.980 --> 00:01:02.690 line:90% align:center
<Default><b>[earring jingles]</b></Default>

c0000013
00:01:05.150 --> 00:01:06.440 line:90% align:center
<Default><b>It looks good on you.</b></Default>

c0000014
00:01:07.280 --> 00:01:08.320 line:90% align:center
<Default><b>See for yourself.</b></Default>

c0000015
00:01:12.110 --> 00:01:13.200 line:90% align:center
<Default><b>[chuckles softly]</b></Default>

c0000016
00:01:13.740 --> 00:01:15.910 line:90% align:center
<Default><b>I leave Gregorio's
secret spell to you.</b></Default>

c0000017
00:01:16.450 --> 00:01:17.870 line:90% align:center
<Default><b>[MIZERHYBY]
You think the stars and moons</b></Default>

c0000018
00:01:17.950 --> 00:01:18.950 line:90% align:center
<Default><b>will come to steal it?</b></Default>

c0000019
00:01:19.410 --> 00:01:20.540 line:90% align:center
<Default><b>[TALISMAN]
It's a possibility.</b></Default>

c0000020
00:01:20.830 --> 00:01:21.960 line:90% align:center
<Default><b>I wouldn't be surprised</b></Default>

c0000021
00:01:22.040 --> 00:01:24.080 line:90% align:center
<Default><b>by some kind of movement
in the future.</b></Default>

c0000022
00:01:24.540 --> 00:01:25.840 line:90% align:center
<Default><b>[chuckles]</b></Default>

c0000023
00:01:26.040 --> 00:01:28.590 line:90% align:center
<Default><b>You know as well as I do
that the moon and stars</b></Default>

c0000024
00:01:28.670 --> 00:01:30.800 line:90% align:center
<Default><b>are merely
a prelude to the sunrise.</b></Default>

c0000025
00:01:31.010 --> 00:01:33.140 line:90% align:center
<Default><b>Take care not
to underestimate them.</b></Default>

c0000026
00:01:33.340 --> 00:01:35.390 line:90% align:center
<Default><b>Especially, the one
from the stars.</b></Default>

c0000027
00:01:35.470 --> 00:01:36.470 line:90% align:center
<Default><b>[MIZERHYBY]
Uncle,</b></Default>

c0000028
00:01:36.560 --> 00:01:37.850 line:90% align:center
<Default><b>do you truly believe</b></Default>

c0000029
00:01:37.930 --> 00:01:40.100 line:90% align:center
<Default><b>Aliceliese can hold
a candle to me?</b></Default>

c0000030
00:01:40.230 --> 00:01:42.480 line:90% align:center
<Default><b>She does have a sharp mind,
make no mistake.</b></Default>

c0000031
00:01:42.730 --> 00:01:44.310 line:90% align:center
<Default><b>To rescue dear Lady Sisbell,</b></Default>

c0000032
00:01:44.440 --> 00:01:46.320 line:90% align:center
<Default><b>she may send over
some servants.</b></Default>

c0000033
00:01:46.480 --> 00:01:47.820 line:90% align:center
<Default><b>[Mizerhyby chuckles]</b></Default>

c0000034
00:01:48.190 --> 00:01:49.360 line:90% align:center
<Default><b>[MIZERHYBY]
Sounds delightful!</b></Default>

c0000035
00:01:49.440 --> 00:01:51.200 line:90% align:center
<Default><b>I'll brew up a very special tea</b></Default>

c0000036
00:01:51.320 --> 00:01:52.990 line:90% align:center
<Default><b>and warm welcome to greet them.</b></Default>

c0000037
00:01:53.360 --> 00:01:55.320 line:90% align:center
<Default><b>Make it dazzling...Mizzy.</b></Default>

c0000038
00:01:55.620 --> 00:01:57.740 line:90% align:center
<Default><b>I'd expect nothing less
from an astral mage</b></Default>

c0000039
00:01:57.830 --> 00:01:59.540 line:90% align:center
<Default><b>and candidate
for the Queen's seat.</b></Default>

c0000040
00:01:59.700 --> 00:02:00.790 line:90% align:center
<Default><b>[chuckles softly]</b></Default>

c0000041
00:02:01.000 --> 00:02:02.580 line:90% align:center
<Default><b>[MIZERHYBY]
I'm looking forward to it.</b></Default>

c0000042
00:02:03.710 --> 00:02:05.750 line:90% align:center
<Default><b>[JHIN] Okay.
We could start a search party,</b></Default>

c0000043
00:02:06.080 --> 00:02:08.000 line:90% align:center
<Default><b>but we have no clue
where to start looking.</b></Default>

c0000044
00:02:08.090 --> 00:02:08.630 line:90% align:center
<Default><b>MORNING STAR: SNOW THE SUN</b></Default>

c0000045
00:02:08.710 --> 00:02:10.130 line:90% align:center
<Default><b>Got any ideas for us, team?</b></Default>

c0000046
00:02:10.880 --> 00:02:13.130 line:90% align:center
<Default><b>I guess the Tower of Sun
comes to mind, but...</b></Default>

c0000047
00:02:13.720 --> 00:02:16.010 line:90% align:center
<Default><b>Lord Talisman would have
changed locations.</b></Default>

c0000048
00:02:16.640 --> 00:02:18.260 line:90% align:center
<Default><b>And moved to where?</b></Default>

c0000049
00:02:18.890 --> 00:02:19.890 line:90% align:center
<Default><b>[ALICE]
Snow the Sun.</b></Default>

c0000050
00:02:20.140 --> 00:02:21.060 line:90% align:center
<Default><b>Hydra's facility</b></Default>

c0000051
00:02:21.140 --> 00:02:23.060 line:90% align:center
<Default><b>on the outskirts
of the Central Province.</b></Default>

c0000052
00:02:24.350 --> 00:02:25.520 line:90% align:center
<Default><b>Starting tomorrow,</b></Default>

c0000053
00:02:25.690 --> 00:02:27.270 line:90% align:center
<Default><b>the royal families
of the Sovereignty</b></Default>

c0000054
00:02:27.360 --> 00:02:28.360 line:90% align:center
<Default><b>will hold a meeting.</b></Default>

c0000055
00:02:28.520 --> 00:02:30.480 line:90% align:center
<Default><b>The Three Founding
Family conference.</b></Default>

c0000056
00:02:30.900 --> 00:02:31.940 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000057
00:02:32.280 --> 00:02:33.570 line:90% align:center
<Default><b>[RIN]
Lord Talisman's attention</b></Default>

c0000058
00:02:33.650 --> 00:02:35.570 line:90% align:center
<Default><b>will be preoccupied
during the event.</b></Default>

c0000059
00:02:35.780 --> 00:02:37.700 line:90% align:center
<Default><b>Leaving Snow the Sun wide open.</b></Default>

c0000060
00:02:38.580 --> 00:02:40.700 line:90% align:center
<Default><b>Giving all of us
the perfect opportunity</b></Default>

c0000061
00:02:40.950 --> 00:02:42.960 line:90% align:center
<Default><b>to rescue Sisbell
from his clutches.</b></Default>

c0000062
00:02:43.660 --> 00:02:45.290 line:90% align:center
<Default><b>I better return to the palace.</b></Default>

c0000063
00:02:45.500 --> 00:02:46.960 line:90% align:center
<Default><b>I can keep an eye on him.</b></Default>

c0000064
00:02:47.840 --> 00:02:48.840 line:90% align:center
<Default><b>Uh.</b></Default>

c0000065
00:02:49.670 --> 00:02:51.050 line:90% align:center
<Default><b>I am counting on you all.</b></Default>

c0000066
00:02:51.300 --> 00:02:52.300 line:90% align:center
<Default><b>Bring her home.</b></Default>

c0000067
00:02:53.340 --> 00:02:56.300 line:90% align:center
<Default><b>[car accelerates]</b></Default>

c0000068
00:02:57.510 --> 00:02:58.510 line:90% align:center
<Default><b>Out with it.</b></Default>

c0000069
00:02:58.680 --> 00:02:59.680 line:90% align:center
<Default><b>What's the matter?</b></Default>

c0000070
00:03:00.600 --> 00:03:03.140 line:90% align:center
<Default><b>This might be out of line
considering my position.</b></Default>

c0000071
00:03:03.930 --> 00:03:06.980 line:90% align:center
<Default><b>But I was wondering
if Johaim is really our guy.</b></Default>

c0000072
00:03:08.610 --> 00:03:09.610 line:90% align:center
<Default><b>Hm.</b></Default>

c0000073
00:03:11.110 --> 00:03:13.530 line:90% align:center
<Default><b>A tall man who carried
an impressive blade.</b></Default>

c0000074
00:03:14.070 --> 00:03:15.400 line:90% align:center
<Default><b>He had red hair,</b></Default>

c0000075
00:03:15.530 --> 00:03:17.870 line:90% align:center
<Default><b>and he wore a suit of armor
underneath a coat.</b></Default>

c0000076
00:03:19.120 --> 00:03:20.910 line:90% align:center
<Default><b>Yeah.
That sounds like him.</b></Default>

c0000077
00:03:22.160 --> 00:03:23.660 line:90% align:center
<Default><b>Well, then, what's the problem?</b></Default>

c0000078
00:03:24.660 --> 00:03:26.920 line:90% align:center
<Default><b>You said that
Elletear was cut down, right?</b></Default>

c0000079
00:03:27.880 --> 00:03:28.960 line:90% align:center
<Default><b>Need I repeat?</b></Default>

c0000080
00:03:29.750 --> 00:03:32.130 line:90% align:center
<Default><b>Lady Elletear threw herself
at an Imperial,</b></Default>

c0000081
00:03:32.460 --> 00:03:33.840 line:90% align:center
<Default><b>all to protect the Queen.</b></Default>

c0000082
00:03:34.510 --> 00:03:36.550 line:90% align:center
<Default><b>Lady Alice and I
both witnessed it.</b></Default>

c0000083
00:03:37.380 --> 00:03:39.550 line:90% align:center
<Default><b>And then, she was
taken captive by Johaim?</b></Default>

c0000084
00:03:40.100 --> 00:03:41.310 line:90% align:center
<Default><b>In cold blood.</b></Default>

c0000085
00:03:41.470 --> 00:03:43.850 line:90% align:center
<Default><b>Neither of us knows
if she is dead or alive.</b></Default>

c0000086
00:03:44.060 --> 00:03:45.930 line:90% align:center
<Default><b>Yeah, that's the part
I find confusing.</b></Default>

c0000087
00:03:46.100 --> 00:03:47.850 line:90% align:center
<Default><b>Doesn't add up
the more I think about it.</b></Default>

c0000088
00:03:48.770 --> 00:03:50.900 line:90% align:center
<Default><b>Uh.
What exactly are you implying?</b></Default>

c0000089
00:03:51.020 --> 00:03:52.820 line:90% align:center
<Default><b>Why wouldn't
he have killed her instantly?</b></Default>

c0000090
00:03:54.860 --> 00:03:56.900 line:90% align:center
<Default><b>Taking her hostage
means she's alive.</b></Default>

c0000091
00:03:57.450 --> 00:03:59.240 line:90% align:center
<Default><b>Cut by a Saint Disciple?</b></Default>

c0000092
00:03:59.530 --> 00:04:02.660 line:90% align:center
<Default><b>To be cut down with that sword
always means instant death.</b></Default>

c0000093
00:04:03.240 --> 00:04:04.950 line:90% align:center
<Default><b>Makes me think
something else is up.</b></Default>

c0000094
00:04:05.040 --> 00:04:06.960 line:90% align:center
<Default><b>♪</b></Default>

c0000095
00:04:07.250 --> 00:04:09.040 line:90% align:center
<Default><b>So, you're saying
it was all an act?</b></Default>

c0000096
00:04:09.830 --> 00:04:11.040 line:90% align:center
<Default><b>Mm-hmm.</b></Default>

c0000097
00:04:11.420 --> 00:04:13.250 line:90% align:center
<Default><b>No, that makes no sense.</b></Default>

c0000098
00:04:13.670 --> 00:04:15.960 line:90% align:center
<Default><b>Why would she do
something like that on purpose?</b></Default>

c0000099
00:04:17.260 --> 00:04:19.590 line:90% align:center
<Default><b>I still can't get the image
out of my head.</b></Default>

c0000100
00:04:20.390 --> 00:04:22.010 line:90% align:center
<Default><b>The floor stained
with her blood.</b></Default>

c0000101
00:04:22.430 --> 00:04:23.430 line:90% align:center
<Default><b>It haunts me!</b></Default>

c0000102
00:04:23.510 --> 00:04:24.850 line:90% align:center
<Default><b>I know you saw it, Rin.</b></Default>

c0000103
00:04:25.060 --> 00:04:27.640 line:90% align:center
<Default><b>The monster who was
cut by a Hydra killer's sword.</b></Default>

c0000104
00:04:28.270 --> 00:04:30.980 line:90% align:center
<Default><b>-And was totally unfazed.
-[gasps]</b></Default>

c0000105
00:04:32.110 --> 00:04:33.610 line:90% align:center
<Default><b>I refuse to believe it.</b></Default>

c0000106
00:04:34.230 --> 00:04:35.940 line:90% align:center
<Default><b>They are not one and the same.</b></Default>

c0000107
00:04:36.610 --> 00:04:38.740 line:90% align:center
<Default><b>But you can't deny
the similarities.</b></Default>

c0000108
00:04:40.030 --> 00:04:41.740 line:90% align:center
<Default><b>I think this was
part of her plan.</b></Default>

c0000109
00:04:41.990 --> 00:04:43.280 line:90% align:center
<Default><b>To escape the castle.</b></Default>

c0000110
00:04:44.910 --> 00:04:47.450 line:90% align:center
<Default><b>She exiled herself
and went to the Empire.</b></Default>

c0000111
00:04:49.210 --> 00:04:50.830 line:90% align:center
<Default><b>[breathes shakily]</b></Default>

c0000112
00:04:51.210 --> 00:04:52.630 line:90% align:center
<Default><b>At least, that's what I think.</b></Default>

c0000113
00:04:52.840 --> 00:04:55.380 line:90% align:center
<Default><b>But at the end of the day,
we aren't here for Elletear.</b></Default>

c0000114
00:04:55.670 --> 00:04:57.760 line:90% align:center
<Default><b>My team is here
to retrieve Sisbell.</b></Default>

c0000115
00:04:57.920 --> 00:05:00.180 line:90% align:center
<Default><b>Whatever else happens is
none of our concern.</b></Default>

c0000116
00:05:01.180 --> 00:05:02.890 line:90% align:center
<Default><b>At least we agree on one thing.</b></Default>

c0000117
00:05:05.180 --> 00:05:06.770 line:90% align:center
<Default><b>This is our responsibility.</b></Default>

c0000118
00:05:07.140 --> 00:05:08.480 line:90% align:center
<Default><b>As the House of Lou.</b></Default>

c0000119
00:05:11.020 --> 00:05:12.900 line:90% align:center
<Default><b>This is Hydra's
Advanced Academy</b></Default>

c0000120
00:05:12.980 --> 00:05:15.020 line:90% align:center
<Default><b>and Research Institute
of Astral Spirit,</b></Default>

c0000121
00:05:15.270 --> 00:05:16.860 line:90% align:center
<Default><b>also known as Snow the Sun.</b></Default>

c0000122
00:05:17.360 --> 00:05:20.030 line:90% align:center
<Default><b>An institute that converts
the planet's astral energy</b></Default>

c0000123
00:05:20.150 --> 00:05:21.740 line:90% align:center
<Default><b>to create
an alternative resource</b></Default>

c0000124
00:05:21.820 --> 00:05:23.570 line:90% align:center
<Default><b>in place of electricity
and gas.</b></Default>

c0000125
00:05:23.910 --> 00:05:25.740 line:90% align:center
<Default><b>[RIN] The Three
Founding Family conference</b></Default>

c0000126
00:05:25.830 --> 00:05:27.620 line:90% align:center
<Default><b>will begin at 11:00 a.m. sharp.</b></Default>

c0000127
00:05:28.000 --> 00:05:29.410 line:90% align:center
<Default><b>That is when you will move in,</b></Default>

c0000128
00:05:29.500 --> 00:05:31.080 line:90% align:center
<Default><b>to infiltrate Snow the Sun.</b></Default>

c0000129
00:05:31.620 --> 00:05:34.170 line:90% align:center
<Default><b>The last Imperial soldiers
that attacked the palace</b></Default>

c0000130
00:05:34.250 --> 00:05:36.000 line:90% align:center
<Default><b>were hiding
in the Central Providence.</b></Default>

c0000131
00:05:36.380 --> 00:05:39.300 line:90% align:center
<Default><b>They found Hydra's facility
and managed to infiltrate it.</b></Default>

c0000132
00:05:39.920 --> 00:05:42.220 line:90% align:center
<Default><b>[RIN] And Lady Sisbell
just happened to be there.</b></Default>

c0000133
00:05:42.760 --> 00:05:44.300 line:90% align:center
<Default><b>That will be our cover story.</b></Default>

c0000134
00:05:46.010 --> 00:05:47.220 line:90% align:center
<Default><b>-[light switch clicks]
-These two</b></Default>

c0000135
00:05:47.310 --> 00:05:48.560 line:90% align:center
<Default><b>will accompany you there.</b></Default>

c0000136
00:05:49.390 --> 00:05:50.850 line:90% align:center
<Default><b>Thank you once again
for your help.</b></Default>

c0000137
00:05:51.060 --> 00:05:53.310 line:90% align:center
<Default><b>It's a pleasure.
I am Nami Orcast.</b></Default>

c0000138
00:05:54.020 --> 00:05:55.730 line:90% align:center
<Default><b>I'm Cystea Cuo Katz.</b></Default>

c0000139
00:05:56.320 --> 00:05:57.940 line:90% align:center
<Default><b>When it comes
to our Lady Sisbell,</b></Default>

c0000140
00:05:58.230 --> 00:05:59.940 line:90% align:center
<Default><b>no sacrifice is too great.</b></Default>

c0000141
00:06:00.570 --> 00:06:02.700 line:90% align:center
<Default><b>So, let us begin
with your astral spirits.</b></Default>

c0000142
00:06:03.450 --> 00:06:04.450 line:90% align:center
<Default><b>Nami?</b></Default>

c0000143
00:06:04.620 --> 00:06:05.740 line:90% align:center
<Default><b>First, I'll demonstrate.</b></Default>

c0000144
00:06:05.820 --> 00:06:08.620 line:90% align:center
<Default><b>Behold. My power,
the astral art of fog.</b></Default>

c0000145
00:06:09.700 --> 00:06:10.700 line:90% align:center
<Default><b>Hm.</b></Default>

c0000146
00:06:11.120 --> 00:06:12.370 line:90% align:center
<Default><b>She's gone!</b></Default>

c0000147
00:06:12.540 --> 00:06:13.710 line:90% align:center
<Default><b>I think it's faster than</b></Default>

c0000148
00:06:13.790 --> 00:06:15.710 line:90% align:center
<Default><b>the Empire's
optical camouflage.</b></Default>

c0000149
00:06:16.340 --> 00:06:17.960 line:90% align:center
<Default><b>-Here I am.
-[gasps]</b></Default>

c0000150
00:06:18.130 --> 00:06:19.210 line:90% align:center
<Default><b>When'd you move?</b></Default>

c0000151
00:06:19.920 --> 00:06:21.800 line:90% align:center
<Default><b>[NOEL]
Her speed is quite restricted.</b></Default>

c0000152
00:06:22.050 --> 00:06:23.880 line:90% align:center
<Default><b>Sudden moves like
running or jumping</b></Default>

c0000153
00:06:23.970 --> 00:06:25.640 line:90% align:center
<Default><b>will cancel Nami's camouflage.</b></Default>

c0000154
00:06:26.430 --> 00:06:28.600 line:90% align:center
<Default><b>[NAMI] Plus, this power can
extend to others,</b></Default>

c0000155
00:06:28.890 --> 00:06:30.350 line:90% align:center
<Default><b>for those who touch the crest.</b></Default>

c0000156
00:06:32.480 --> 00:06:33.480 line:90% align:center
<Default><b>[gasps]</b></Default>

c0000157
00:06:33.560 --> 00:06:34.560 line:90% align:center
<Default><b>[MISMIS]
Tee-hee!</b></Default>

c0000158
00:06:34.650 --> 00:06:36.400 line:90% align:center
<Default><b>Try to find us, Iska!</b></Default>

c0000159
00:06:36.480 --> 00:06:38.190 line:90% align:center
<Default><b>[giggles]</b></Default>

c0000160
00:06:38.270 --> 00:06:39.780 line:90% align:center
<Default><b>-Over here!
-[chuckles]</b></Default>

c0000161
00:06:40.070 --> 00:06:41.940 line:90% align:center
<Default><b>The more people
who use her power,</b></Default>

c0000162
00:06:42.150 --> 00:06:43.700 line:90% align:center
<Default><b>the less time it will last.</b></Default>

c0000163
00:06:44.070 --> 00:06:45.110 line:90% align:center
<Default><b>For six people,</b></Default>

c0000164
00:06:45.320 --> 00:06:47.370 line:90% align:center
<Default><b>I'd say the maximum
is around four hours.</b></Default>

c0000165
00:06:47.450 --> 00:06:48.450 line:90% align:center
<Default><b>-Oh!
-Oh!</b></Default>

c0000166
00:06:48.870 --> 00:06:50.410 line:90% align:center
<Default><b>I think I got the gist of it.</b></Default>

c0000167
00:06:51.950 --> 00:06:52.960 line:90% align:center
<Default><b>[gasps]</b></Default>

c0000168
00:06:53.080 --> 00:06:54.920 line:90% align:center
<Default><b>As for my spirit, Echo,</b></Default>

c0000169
00:06:55.000 --> 00:06:57.000 line:90% align:center
<Default><b>it's able to gather
sounds around me.</b></Default>

c0000170
00:06:57.920 --> 00:06:58.920 line:90% align:center
<Default><b>[clears throat]</b></Default>

c0000171
00:06:59.960 --> 00:07:01.260 line:90% align:center
<Default><b>[TOURIST 1] Hm.
Not too bad...</b></Default>

c0000172
00:07:01.340 --> 00:07:03.260 line:90% align:center
<Default><b>[CYSTEA] What you're hearing
is from the 35th floor,</b></Default>

c0000173
00:07:03.340 --> 00:07:04.170 line:90% align:center
<Default><b>-a tourists' room.
-[TOURIST 2] So, what's the</b></Default>

c0000174
00:07:04.260 --> 00:07:05.550 line:90% align:center
<Default><b>plan for tomorrow?</b></Default>

c0000175
00:07:05.800 --> 00:07:07.300 line:90% align:center
<Default><b>And if it's quiet enough,</b></Default>

c0000176
00:07:07.640 --> 00:07:09.930 line:90% align:center
<Default><b>I can pick up sounds
up to five floors away.</b></Default>

c0000177
00:07:10.310 --> 00:07:12.810 line:90% align:center
<Default><b>Also, things like voices
or footsteps,</b></Default>

c0000178
00:07:12.890 --> 00:07:14.310 line:90% align:center
<Default><b>I can muffle no problem.</b></Default>

c0000179
00:07:14.640 --> 00:07:16.850 line:90% align:center
<Default><b>Hey, I know!
Say something to try it out...</b></Default>

c0000180
00:07:20.440 --> 00:07:21.480 line:90% align:center
<Default><b>[NOEL]
Not a peep.</b></Default>

c0000181
00:07:22.030 --> 00:07:23.740 line:90% align:center
<Default><b>Since this power
collects sound,</b></Default>

c0000182
00:07:23.820 --> 00:07:25.450 line:90% align:center
<Default><b>it can prevent its spread, too.</b></Default>

c0000183
00:07:25.570 --> 00:07:27.030 line:90% align:center
<Default><b>So anything that's
spoken out loud</b></Default>

c0000184
00:07:27.110 --> 00:07:28.950 line:90% align:center
<Default><b>can be captured and silenced.</b></Default>

c0000185
00:07:29.370 --> 00:07:31.240 line:90% align:center
<Default><b>Will it work
to diminish gunshots?</b></Default>

c0000186
00:07:31.490 --> 00:07:32.700 line:90% align:center
<Default><b>[CYSTEA]
Unfortunately, no.</b></Default>

c0000187
00:07:32.830 --> 00:07:33.910 line:90% align:center
<Default><b>That settles it.</b></Default>

c0000188
00:07:34.040 --> 00:07:35.710 line:90% align:center
<Default><b>We avoid combat while inside.</b></Default>

c0000189
00:07:36.210 --> 00:07:37.710 line:90% align:center
<Default><b>Meaning we'll rely on Iska,</b></Default>

c0000190
00:07:37.830 --> 00:07:39.000 line:90% align:center
<Default><b>if anything else happens.</b></Default>

c0000191
00:07:39.630 --> 00:07:40.920 line:90% align:center
<Default><b>My sword will be ready.</b></Default>

c0000192
00:07:42.210 --> 00:07:45.010 line:90% align:center
<Default><b>Rin. We should expect
pureblood company, right?</b></Default>

c0000193
00:07:45.420 --> 00:07:46.630 line:90% align:center
<Default><b>It's highly likely.</b></Default>

c0000194
00:07:47.300 --> 00:07:49.470 line:90% align:center
<Default><b>For example,
Princess Mizerhyby.</b></Default>

c0000195
00:07:50.390 --> 00:07:52.970 line:90% align:center
<Default><b>I'll share what I know
about Hydra's military power.</b></Default>

c0000196
00:07:54.770 --> 00:07:56.060 line:90% align:center
<Default><b>The rest is up to you.</b></Default>

c0000197
00:07:56.980 --> 00:07:58.690 line:90% align:center
<Default><b>-Hmm.
-This makes me uneasy, but...</b></Default>

c0000198
00:07:59.150 --> 00:08:00.150 line:90% align:center
<Default><b>I trust you.</b></Default>

c0000199
00:08:00.230 --> 00:08:01.900 line:90% align:center
<Default><b>You'll take care
of Lady Sisbell.</b></Default>

c0000200
00:08:02.360 --> 00:08:03.730 line:90% align:center
<Default><b>I believe in your abilities.</b></Default>

c0000201
00:08:04.400 --> 00:08:05.900 line:90% align:center
<Default><b>Miss Rin?
One question.</b></Default>

c0000202
00:08:06.570 --> 00:08:07.570 line:90% align:center
<Default><b>Yes?</b></Default>

c0000203
00:08:07.740 --> 00:08:09.450 line:90% align:center
<Default><b>[ASHE] Are the two of you
more than "acquainted?"</b></Default>

c0000204
00:08:12.580 --> 00:08:14.040 line:90% align:center
<Default><b>[gasps]</b></Default>

c0000205
00:08:14.290 --> 00:08:16.580 line:90% align:center
<Default><b>Don't get the wrong idea!
I misspoke!</b></Default>

c0000206
00:08:16.660 --> 00:08:17.660 line:90% align:center
<Default><b>Ugh!</b></Default>

c0000207
00:08:20.670 --> 00:08:21.750 line:90% align:center
<Default><b>[knocking on door]</b></Default>

c0000208
00:08:22.000 --> 00:08:24.130 line:90% align:center
<Default><b>[RIN] I apologize for
interrupting your rest,</b></Default>

c0000209
00:08:24.300 --> 00:08:25.300 line:90% align:center
<Default><b>Lady Alice.</b></Default>

c0000210
00:08:25.380 --> 00:08:26.470 line:90% align:center
<Default><b>Great job today.</b></Default>

c0000211
00:08:26.760 --> 00:08:27.760 line:90% align:center
<Default><b>Please, come in.</b></Default>

c0000212
00:08:28.430 --> 00:08:29.680 line:90% align:center
<Default><b>[door opens]</b></Default>

c0000213
00:08:31.600 --> 00:08:32.680 line:90% align:center
<Default><b>[door shuts]</b></Default>

c0000214
00:08:34.310 --> 00:08:35.770 line:90% align:center
<Default><b>[RIN]
I was just doing my job.</b></Default>

c0000215
00:08:35.850 --> 00:08:37.730 line:90% align:center
<Default><b>Your focus should be
on what's ahead.</b></Default>

c0000216
00:08:39.100 --> 00:08:40.100 line:90% align:center
<Default><b>That's right.</b></Default>

c0000217
00:08:40.770 --> 00:08:41.810 line:90% align:center
<Default><b>The conference.</b></Default>

c0000218
00:08:42.190 --> 00:08:44.530 line:90% align:center
<Default><b>No doubt they'll try to
hold my mother accountable.</b></Default>

c0000219
00:08:45.440 --> 00:08:46.740 line:90% align:center
<Default><b>By rescuing Sisbell,</b></Default>

c0000220
00:08:47.360 --> 00:08:49.400 line:90% align:center
<Default><b>we expose Hydra's conspiracy.</b></Default>

c0000221
00:08:50.490 --> 00:08:51.660 line:90% align:center
<Default><b>Failure to do so...</b></Default>

c0000222
00:08:52.240 --> 00:08:53.620 line:90% align:center
<Default><b>will mean the fall of the Lou.</b></Default>

c0000223
00:08:54.450 --> 00:08:57.000 line:90% align:center
<Default><b>The swordsman will make sure
that doesn't come to pass.</b></Default>

c0000224
00:08:57.620 --> 00:08:58.620 line:90% align:center
<Default><b>[gasps]</b></Default>

c0000225
00:09:05.710 --> 00:09:08.630 line:90% align:center
<Default><b>[wind whooshing]</b></Default>

c0000226
00:09:08.840 --> 00:09:09.840 line:90% align:center
<Default><b>[NAMI]
Let's proceed,</b></Default>

c0000227
00:09:10.050 --> 00:09:11.130 line:90% align:center
<Default><b>according to plan.</b></Default>

c0000228
00:09:11.640 --> 00:09:14.260 line:90% align:center
<Default><b>[all patting]</b></Default>

c0000229
00:09:14.680 --> 00:09:16.390 line:90% align:center
<Default><b>♪</b></Default>

c0000230
00:09:17.060 --> 00:09:18.100 line:90% align:center
<Default><b>Everyone!</b></Default>

c0000231
00:09:18.520 --> 00:09:19.600 line:90% align:center
<Default><b>Move out!</b></Default>

c0000232
00:09:19.730 --> 00:09:22.730 line:90% align:center
<Default><b>♪</b></Default>

c0000233
00:09:30.530 --> 00:09:31.530 line:90% align:center
<Default><b>[inhales]</b></Default>

c0000234
00:09:31.700 --> 00:09:32.700 line:90% align:center
<Default><b>[exhales]</b></Default>

c0000235
00:09:33.490 --> 00:09:34.490 line:90% align:center
<Default><b>[door opens]</b></Default>

c0000236
00:09:36.660 --> 00:09:37.700 line:90% align:center
<Default><b>[door shuts]</b></Default>

c0000237
00:09:39.790 --> 00:09:41.290 line:90% align:center
<Default><b>[TALISMAN]
Hello, Lady Alice.</b></Default>

c0000238
00:09:42.170 --> 00:09:44.710 line:90% align:center
<Default><b>I was disappointed to find
you were missing yesterday,</b></Default>

c0000239
00:09:44.880 --> 00:09:47.130 line:90% align:center
<Default><b>but I take it you're in
much better spirits now?</b></Default>

c0000240
00:09:47.550 --> 00:09:48.550 line:90% align:center
<Default><b>I am.</b></Default>

c0000241
00:09:48.630 --> 00:09:49.970 line:90% align:center
<Default><b>Well enough
to review the minutes</b></Default>

c0000242
00:09:50.050 --> 00:09:51.220 line:90% align:center
<Default><b>from the meeting I missed.</b></Default>

c0000243
00:09:51.970 --> 00:09:53.340 line:90% align:center
<Default><b>[TALISMAN]
That's what I like to hear.</b></Default>

c0000244
00:09:53.930 --> 00:09:56.050 line:90% align:center
<Default><b>Did an emergency
of some kind pop up?</b></Default>

c0000245
00:09:56.310 --> 00:09:58.930 line:90% align:center
<Default><b>You looked so distraught
when I saw you last.</b></Default>

c0000246
00:09:59.390 --> 00:10:00.390 line:90% align:center
<Default><b>[gasps]</b></Default>

c0000247
00:10:00.730 --> 00:10:02.520 line:90% align:center
<Default><b>How thoughtful of you
to be concerned.</b></Default>

c0000248
00:10:03.270 --> 00:10:05.650 line:90% align:center
<Default><b>I've never been in
this kind of situation before.</b></Default>

c0000249
00:10:06.770 --> 00:10:08.650 line:90% align:center
<Default><b>[ALICE] Did he pick that up
from my expression?</b></Default>

c0000250
00:10:09.440 --> 00:10:10.940 line:90% align:center
<Default><b>No.
Couldn't have.</b></Default>

c0000251
00:10:11.570 --> 00:10:13.490 line:90% align:center
<Default><b>Don't push yourself, my lady.</b></Default>

c0000252
00:10:14.280 --> 00:10:15.370 line:90% align:center
<Default><b>[ALICE]
Little by little,</b></Default>

c0000253
00:10:15.570 --> 00:10:17.330 line:90% align:center
<Default><b>he's noticing
we're up to something.</b></Default>

c0000254
00:10:19.330 --> 00:10:21.500 line:90% align:center
<Default><b>Lord Talisman and Masked Lord.</b></Default>

c0000255
00:10:21.790 --> 00:10:23.920 line:90% align:center
<Default><b>These two are far better
talkers than I am.</b></Default>

c0000256
00:10:24.790 --> 00:10:26.590 line:90% align:center
<Default><b>All it takes is one slip-up,</b></Default>

c0000257
00:10:26.710 --> 00:10:29.090 line:90% align:center
<Default><b>and I could jeopardize
the entire plan.</b></Default>

c0000258
00:10:30.340 --> 00:10:31.340 line:90% align:center
<Default><b>I can't let them know</b></Default>

c0000259
00:10:31.420 --> 00:10:32.930 line:90% align:center
<Default><b>what Iska
and the others are doing.</b></Default>

c0000260
00:10:34.130 --> 00:10:35.140 line:90% align:center
<Default><b>Therefore,</b></Default>

c0000261
00:10:35.390 --> 00:10:37.140 line:90% align:center
<Default><b>silence is my best option.</b></Default>

c0000262
00:10:37.350 --> 00:10:39.850 line:90% align:center
<Default><b>[footsteps approaches]</b></Default>

c0000263
00:10:42.230 --> 00:10:43.230 line:90% align:center
<Default><b>Hm.</b></Default>

c0000264
00:10:44.940 --> 00:10:47.020 line:90% align:center
<Default><b>The conference will
begin momentarily.</b></Default>

c0000265
00:10:47.480 --> 00:10:48.980 line:90% align:center
<Default><b>It's nearly 11:00 a.m.</b></Default>

c0000266
00:10:50.230 --> 00:10:51.240 line:90% align:center
<Default><b>Hm.</b></Default>

c0000267
00:10:53.360 --> 00:10:54.360 line:90% align:center
<Default><b>[NAMI]
Get ready.</b></Default>

c0000268
00:10:54.450 --> 00:10:55.860 line:90% align:center
<Default><b>Our mission is starting soon.</b></Default>

c0000269
00:10:56.240 --> 00:10:57.950 line:90% align:center
<Default><b>Just a few more seconds
'til 11:00.</b></Default>

c0000270
00:10:58.660 --> 00:10:59.660 line:90% align:center
<Default><b>-Got it.
-[clock ticks]</b></Default>

c0000271
00:11:00.450 --> 00:11:02.000 line:90% align:center
<Default><b>[clock ticking]</b></Default>

c0000272
00:11:02.370 --> 00:11:03.460 line:90% align:center
<Default><b>-The Three Founding...
-Lady Sisbell's rescue</b></Default>

c0000273
00:11:03.540 --> 00:11:04.500 line:90% align:center
<Default><b>-mission...
-...Family conference...</b></Default>

c0000274
00:11:04.790 --> 00:11:06.380 line:90% align:center
<Default><b>[MILLAVAIR, NAMI]
Will start now.</b></Default>

c0000275
00:11:07.540 --> 00:11:09.090 line:90% align:center
<Default><b>Keep a low profile, okay?</b></Default>

c0000276
00:11:09.340 --> 00:11:10.840 line:90% align:center
<Default><b>Until we rescue Sisbell.</b></Default>

c0000277
00:11:11.340 --> 00:11:13.510 line:90% align:center
<Default><b>♪</b></Default>

c0000278
00:11:13.590 --> 00:11:14.590 line:90% align:center
<Default><b>[Mismis gasps]</b></Default>

c0000279
00:11:14.800 --> 00:11:17.800 line:90% align:center
<Default><b>♪</b></Default>

c0000280
00:11:23.850 --> 00:11:24.850 line:90% align:center
<Default><b>[gasps]</b></Default>

c0000281
00:11:25.140 --> 00:11:28.150 line:90% align:center
<Default><b>♪</b></Default>

c0000282
00:11:28.400 --> 00:11:29.400 line:90% align:center
<Default><b>[sighs]</b></Default>

c0000283
00:11:29.730 --> 00:11:30.730 line:90% align:center
<Default><b>[MISMIS]
It works.</b></Default>

c0000284
00:11:30.900 --> 00:11:32.400 line:90% align:center
<Default><b>They really don't see us.</b></Default>

c0000285
00:11:33.320 --> 00:11:34.320 line:90% align:center
<Default><b>[door slides open]</b></Default>

c0000286
00:11:34.530 --> 00:11:37.530 line:90% align:center
<Default><b>♪</b></Default>

c0000287
00:11:38.660 --> 00:11:39.910 line:90% align:center
<Default><b>No lollygagging!</b></Default>

c0000288
00:11:40.030 --> 00:11:41.660 line:90% align:center
<Default><b>The door's gonna close,
Captain!</b></Default>

c0000289
00:11:41.990 --> 00:11:43.000 line:90% align:center
<Default><b>Uh!</b></Default>

c0000290
00:11:43.080 --> 00:11:44.200 line:90% align:center
<Default><b>[MISMIS]
Sorry, sorry!</b></Default>

c0000291
00:11:45.410 --> 00:11:46.250 line:90% align:center
<Default><b>[Mismis pants]</b></Default>

c0000292
00:11:46.370 --> 00:11:47.710 line:90% align:center
<Default><b>Made it just in time!</b></Default>

c0000293
00:11:48.210 --> 00:11:50.210 line:90% align:center
<Default><b>Good thing we did
a test run yesterday.</b></Default>

c0000294
00:11:50.380 --> 00:11:51.840 line:90% align:center
<Default><b>We're much more in sync!</b></Default>

c0000295
00:11:52.130 --> 00:11:54.340 line:90% align:center
<Default><b>That "test run" was
mainly for you, boss.</b></Default>

c0000296
00:11:54.510 --> 00:11:55.720 line:90% align:center
<Default><b>[MISMIS]
Don't be mean--</b></Default>

c0000297
00:11:56.380 --> 00:11:57.760 line:90% align:center
<Default><b>"Low profile," remember?</b></Default>

c0000298
00:11:58.390 --> 00:12:00.050 line:90% align:center
<Default><b>There's a limit
to this sound chamber.</b></Default>

c0000299
00:12:00.720 --> 00:12:02.930 line:90% align:center
<Default><b>From here on,
this is enemy territory.</b></Default>

c0000300
00:12:04.930 --> 00:12:05.930 line:90% align:center
<Default><b>[NENE]
Wow!</b></Default>

c0000301
00:12:06.270 --> 00:12:08.850 line:90% align:center
<Default><b>It's kinda looks like
the Empire's research facility.</b></Default>

c0000302
00:12:09.730 --> 00:12:12.070 line:90% align:center
<Default><b>Apparently,
this duct sends astral energy</b></Default>

c0000303
00:12:12.150 --> 00:12:14.820 line:90% align:center
<Default><b>from an underground vortex
at the planet's core.</b></Default>

c0000304
00:12:16.400 --> 00:12:18.490 line:90% align:center
<Default><b>With all the foot traffic
going in and out,</b></Default>

c0000305
00:12:18.820 --> 00:12:21.200 line:90% align:center
<Default><b>I can't think of many places
to hold a prisoner.</b></Default>

c0000306
00:12:23.290 --> 00:12:25.120 line:90% align:center
<Default><b>[JHIN]
Setting aside private soldiers,</b></Default>

c0000307
00:12:25.250 --> 00:12:27.370 line:90% align:center
<Default><b>it's highly unlikely that
hundreds of researchers</b></Default>

c0000308
00:12:27.460 --> 00:12:29.880 line:90% align:center
<Default><b>are also in the know
about Hydra's conspiracy.</b></Default>

c0000309
00:12:31.250 --> 00:12:32.500 line:90% align:center
<Default><b>[MISMIS]
Narrowing our choices</b></Default>

c0000310
00:12:32.590 --> 00:12:35.590 line:90% align:center
<Default><b>to unauthorized locations
researchers can't access.</b></Default>

c0000311
00:12:35.840 --> 00:12:37.590 line:90% align:center
<Default><b>The top-level research lab.</b></Default>

c0000312
00:12:37.720 --> 00:12:39.340 line:90% align:center
<Default><b>Hydra's hall on the top floor.</b></Default>

c0000313
00:12:39.680 --> 00:12:42.350 line:90% align:center
<Default><b>Or maybe the accumulation area
in the basement.</b></Default>

c0000314
00:12:42.850 --> 00:12:44.140 line:90% align:center
<Default><b>-[CYSTEA] Captain Mismis.
-Uh.</b></Default>

c0000315
00:12:44.720 --> 00:12:47.100 line:90% align:center
<Default><b>Around four floors below us
I hear something.</b></Default>

c0000316
00:12:47.350 --> 00:12:48.350 line:90% align:center
<Default><b>It's weak,</b></Default>

c0000317
00:12:48.440 --> 00:12:49.940 line:90% align:center
<Default><b>but I hear someone breathing.</b></Default>

c0000318
00:12:50.980 --> 00:12:52.810 line:90% align:center
<Default><b>-[all gasp] -So, that's where
they're keeping her?</b></Default>

c0000319
00:12:54.020 --> 00:12:55.780 line:90% align:center
<Default><b>There's only one way
to find out.</b></Default>

c0000320
00:12:56.360 --> 00:12:57.360 line:90% align:center
<Default><b>Hm.</b></Default>

c0000321
00:12:58.070 --> 00:12:59.240 line:90% align:center
<Default><b>To the basement.</b></Default>

c0000322
00:12:59.700 --> 00:13:00.860 line:90% align:center
<Default><b>[elevator bell dings]</b></Default>

c0000323
00:13:01.070 --> 00:13:04.080 line:90% align:center
<Default><b>[elevator whirring]</b></Default>

c0000324
00:13:07.040 --> 00:13:08.290 line:90% align:center
<Default><b>[MASKED LORD]
Pardon, Your Highness.</b></Default>

c0000325
00:13:08.370 --> 00:13:10.210 line:90% align:center
<Default><b>Do forgive me
for being this blunt.</b></Default>

c0000326
00:13:10.420 --> 00:13:12.750 line:90% align:center
<Default><b>But I must say I'm rather
disappointed in you.</b></Default>

c0000327
00:13:13.960 --> 00:13:15.130 line:90% align:center
<Default><b>Under your watch,</b></Default>

c0000328
00:13:15.250 --> 00:13:17.460 line:90% align:center
<Default><b>the Imperial Army
invaded the palace.</b></Default>

c0000329
00:13:17.920 --> 00:13:20.840 line:90% align:center
<Default><b>A national disgrace,
unheard of since the founding.</b></Default>

c0000330
00:13:21.510 --> 00:13:23.470 line:90% align:center
<Default><b>Not to mention
that the Zoa family</b></Default>

c0000331
00:13:23.550 --> 00:13:25.390 line:90% align:center
<Default><b>has been deprived
of their chief.</b></Default>

c0000332
00:13:25.760 --> 00:13:26.850 line:90% align:center
<Default><b>It's obvious by now</b></Default>

c0000333
00:13:26.930 --> 00:13:29.230 line:90% align:center
<Default><b>Growley has been kidnapped
by the Empire.</b></Default>

c0000334
00:13:29.430 --> 00:13:30.440 line:90% align:center
<Default><b>[Millavair gasps]</b></Default>

c0000335
00:13:30.980 --> 00:13:32.560 line:90% align:center
<Default><b>Please understand, Lord On!</b></Default>

c0000336
00:13:32.810 --> 00:13:35.230 line:90% align:center
<Default><b>This ordeal has been
just as hard for the Queen!</b></Default>

c0000337
00:13:35.480 --> 00:13:36.650 line:90% align:center
<Default><b>Show compassion.</b></Default>

c0000338
00:13:36.730 --> 00:13:39.820 line:90% align:center
<Default><b>Lady Elletear and Lady Sisbell
are missing as well!</b></Default>

c0000339
00:13:41.740 --> 00:13:42.740 line:90% align:center
<Default><b>If I may,</b></Default>

c0000340
00:13:42.950 --> 00:13:44.830 line:90% align:center
<Default><b>now is not the time
to point fingers</b></Default>

c0000341
00:13:44.910 --> 00:13:46.370 line:90% align:center
<Default><b>and assign blame
for the attack.</b></Default>

c0000342
00:13:46.540 --> 00:13:48.790 line:90% align:center
<Default><b>Our time is better spent
on a rescue plan.</b></Default>

c0000343
00:13:49.040 --> 00:13:51.250 line:90% align:center
<Default><b>The era of passivity is past.</b></Default>

c0000344
00:13:51.710 --> 00:13:53.000 line:90% align:center
<Default><b>The only way to rescue them</b></Default>

c0000345
00:13:53.080 --> 00:13:55.000 line:90% align:center
<Default><b>-is an all-out attack
on the Empire. -[gasps]</b></Default>

c0000346
00:13:55.920 --> 00:13:57.380 line:90% align:center
<Default><b>Polite negotiation?</b></Default>

c0000347
00:13:57.590 --> 00:13:59.880 line:90% align:center
<Default><b>Over a table
surrounded by delegates?</b></Default>

c0000348
00:14:00.340 --> 00:14:01.550 line:90% align:center
<Default><b>Wipe away the thought.</b></Default>

c0000349
00:14:02.050 --> 00:14:03.470 line:90% align:center
<Default><b>It won't bring back our people.</b></Default>

c0000350
00:14:03.640 --> 00:14:05.800 line:90% align:center
<Default><b>Purebloods are nothing
more than lab rats.</b></Default>

c0000351
00:14:05.930 --> 00:14:07.470 line:90% align:center
<Default><b>Lower than hostages to them.</b></Default>

c0000352
00:14:08.520 --> 00:14:10.680 line:90% align:center
<Default><b>You wish to negotiate
with a party</b></Default>

c0000353
00:14:10.770 --> 00:14:12.600 line:90% align:center
<Default><b>that never had
our best interests in mind</b></Default>

c0000354
00:14:12.690 --> 00:14:13.770 line:90% align:center
<Default><b>from the very beginning?</b></Default>

c0000355
00:14:14.100 --> 00:14:16.570 line:90% align:center
<Default><b>And you know full well
how they treat prisoners.</b></Default>

c0000356
00:14:17.230 --> 00:14:18.820 line:90% align:center
<Default><b>I understand that.</b></Default>

c0000357
00:14:19.230 --> 00:14:20.240 line:90% align:center
<Default><b>[walking stick thuds]</b></Default>

c0000358
00:14:20.360 --> 00:14:21.200 line:90% align:center
<Default><b>Do you?</b></Default>

c0000359
00:14:21.320 --> 00:14:23.700 line:90% align:center
<Default><b>Then you agree to an all-out
attack on the mainland?</b></Default>

c0000360
00:14:24.870 --> 00:14:26.030 line:90% align:center
<Default><b>[MILLAVAIR]
Unacceptable.</b></Default>

c0000361
00:14:26.620 --> 00:14:29.830 line:90% align:center
<Default><b>This proposal will only
result in needless casualties.</b></Default>

c0000362
00:14:29.910 --> 00:14:31.870 line:90% align:center
<Default><b>As Queen,
I won't allow that to happen.</b></Default>

c0000363
00:14:32.710 --> 00:14:34.210 line:90% align:center
<Default><b>[scoffs]
Perhaps you're unfit</b></Default>

c0000364
00:14:34.290 --> 00:14:36.290 line:90% align:center
<Default><b>to make that call
as our Monarch.</b></Default>

c0000365
00:14:36.460 --> 00:14:37.500 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000366
00:14:38.380 --> 00:14:39.380 line:90% align:center
<Default><b>[whispered indistinct chatter]</b></Default>

c0000367
00:14:40.170 --> 00:14:42.090 line:90% align:center
<Default><b>[TALISMAN]
True, you have a point.</b></Default>

c0000368
00:14:42.720 --> 00:14:44.720 line:90% align:center
<Default><b>We should conduct
the Queen's election.</b></Default>

c0000369
00:14:45.220 --> 00:14:46.930 line:90% align:center
<Default><b>During unprecedented times,</b></Default>

c0000370
00:14:47.010 --> 00:14:48.310 line:90% align:center
<Default><b>it's common for new leadership</b></Default>

c0000371
00:14:48.390 --> 00:14:50.600 line:90% align:center
<Default><b>to rise to the occasion
amidst the chaos.</b></Default>

c0000372
00:14:51.270 --> 00:14:52.520 line:90% align:center
<Default><b>Is that what you mean?</b></Default>

c0000373
00:14:53.600 --> 00:14:54.770 line:90% align:center
<Default><b>[chuckles softly]
No.</b></Default>

c0000374
00:14:55.810 --> 00:14:56.940 line:90% align:center
<Default><b>[elevator door opens]</b></Default>

c0000375
00:14:57.560 --> 00:15:00.570 line:90% align:center
<Default><b>♪</b></Default>

c0000376
00:15:04.150 --> 00:15:05.950 line:90% align:center
<Default><b>[CYSTEA] This way.
Not much further.</b></Default>

c0000377
00:15:08.240 --> 00:15:09.240 line:90% align:center
<Default><b>Hm.</b></Default>

c0000378
00:15:09.540 --> 00:15:12.500 line:90% align:center
<Default><b>♪</b></Default>

c0000379
00:15:13.790 --> 00:15:15.670 line:90% align:center
<Default><b>[CYSTEA]
Behind that material storage.</b></Default>

c0000380
00:15:16.540 --> 00:15:18.790 line:90% align:center
<Default><b>[MISMIS] They left Sisbell
in a place like that?</b></Default>

c0000381
00:15:19.210 --> 00:15:21.630 line:90% align:center
<Default><b>[CYSTEA] It may not necessarily
be Lady Sisbell.</b></Default>

c0000382
00:15:21.800 --> 00:15:23.630 line:90% align:center
<Default><b>I just sense
a faint presence here.</b></Default>

c0000383
00:15:24.260 --> 00:15:25.340 line:90% align:center
<Default><b>[gasps]</b></Default>

c0000384
00:15:26.050 --> 00:15:27.510 line:90% align:center
<Default><b>[JHIN]
He's Sisbell's servant.</b></Default>

c0000385
00:15:28.140 --> 00:15:29.510 line:90% align:center
<Default><b>Nene.
You got this?</b></Default>

c0000386
00:15:29.970 --> 00:15:31.810 line:90% align:center
<Default><b>Yes, sir, evidence captured!</b></Default>

c0000387
00:15:32.310 --> 00:15:34.100 line:90% align:center
<Default><b>This means
she has to be nearby,</b></Default>

c0000388
00:15:34.230 --> 00:15:35.600 line:90% align:center
<Default><b>since Schwartz is here!</b></Default>

c0000389
00:15:35.980 --> 00:15:37.600 line:90% align:center
<Default><b>No sign of anybody else.</b></Default>

c0000390
00:15:38.400 --> 00:15:40.480 line:90% align:center
<Default><b>My guess is,
she's not in the basement.</b></Default>

c0000391
00:15:41.150 --> 00:15:43.440 line:90% align:center
<Default><b>Right.
That just leaves the upstairs.</b></Default>

c0000392
00:15:44.990 --> 00:15:46.490 line:90% align:center
<Default><b>[JHIN] Nene.
Can you do something</b></Default>

c0000393
00:15:46.570 --> 00:15:47.820 line:90% align:center
<Default><b>about that surveillance camera?</b></Default>

c0000394
00:15:48.820 --> 00:15:50.080 line:90% align:center
<Default><b>As much as I wanna,</b></Default>

c0000395
00:15:50.160 --> 00:15:51.160 line:90% align:center
<Default><b>messing with the camera will</b></Default>

c0000396
00:15:51.240 --> 00:15:52.660 line:90% align:center
<Default><b>set off all kinds
of alarm bells</b></Default>

c0000397
00:15:52.740 --> 00:15:54.290 line:90% align:center
<Default><b>for whoever's
patrolling the place.</b></Default>

c0000398
00:15:54.620 --> 00:15:56.420 line:90% align:center
<Default><b>Jamming it
blows our cover early.</b></Default>

c0000399
00:15:56.870 --> 00:15:57.880 line:90% align:center
<Default><b>Get Sisbell.</b></Default>

c0000400
00:15:57.960 --> 00:15:58.960 line:90% align:center
<Default><b>Come back for him.</b></Default>

c0000401
00:15:59.290 --> 00:16:00.670 line:90% align:center
<Default><b>Well, boss?
Sound good?</b></Default>

c0000402
00:16:01.210 --> 00:16:02.840 line:90% align:center
<Default><b>I hate to be so practical,</b></Default>

c0000403
00:16:03.010 --> 00:16:05.590 line:90% align:center
<Default><b>but our number one priority
is saving Sisbell.</b></Default>

c0000404
00:16:07.090 --> 00:16:08.300 line:90% align:center
<Default><b>[NAMI, CYSTEA]
As you say, Captain.</b></Default>

c0000405
00:16:11.970 --> 00:16:13.970 line:90% align:center
<Default><b>[JHIN] Let's take this
as far as we can.</b></Default>

c0000406
00:16:14.560 --> 00:16:15.560 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000407
00:16:15.640 --> 00:16:16.810 line:90% align:center
<Default><b>[elevator bell dings]</b></Default>

c0000408
00:16:17.560 --> 00:16:18.810 line:90% align:center
<Default><b>Listen up, everyone.</b></Default>

c0000409
00:16:19.020 --> 00:16:20.230 line:90% align:center
<Default><b>No matter what happens,</b></Default>

c0000410
00:16:20.310 --> 00:16:22.440 line:90% align:center
<Default><b>we can't afford
to lose sight of our goal.</b></Default>

c0000411
00:16:22.820 --> 00:16:24.860 line:90% align:center
<Default><b>Anyone could be
beyond these doors.</b></Default>

c0000412
00:16:25.280 --> 00:16:27.610 line:90% align:center
<Default><b>So stay alert,
and don't break cover.</b></Default>

c0000413
00:16:28.110 --> 00:16:29.240 line:90% align:center
<Default><b>[ALL]
Hm.</b></Default>

c0000414
00:16:29.320 --> 00:16:30.450 line:90% align:center
<Default><b>[elevator bell dings]</b></Default>

c0000415
00:16:30.530 --> 00:16:31.530 line:90% align:center
<Default><b>[door slides open]</b></Default>

c0000416
00:16:38.710 --> 00:16:39.710 line:90% align:center
<Default><b>[Mismis gasps]</b></Default>

c0000417
00:16:39.790 --> 00:16:41.540 line:90% align:center
<Default><b>Great.
She's in here, too?</b></Default>

c0000418
00:16:43.750 --> 00:16:45.090 line:90% align:center
<Default><b>What do you think, Jhin?</b></Default>

c0000419
00:16:45.960 --> 00:16:46.970 line:90% align:center
<Default><b>From the look of things,</b></Default>

c0000420
00:16:47.050 --> 00:16:48.800 line:90% align:center
<Default><b>it doesn't seem like
this is an ambush.</b></Default>

c0000421
00:16:49.680 --> 00:16:51.390 line:90% align:center
<Default><b>She's just taking the elevator.</b></Default>

c0000422
00:16:54.850 --> 00:16:56.060 line:90% align:center
<Default><b>[elevator bell dings]</b></Default>

c0000423
00:16:56.180 --> 00:16:57.310 line:90% align:center
<Default><b>[door slides open]</b></Default>

c0000424
00:17:03.900 --> 00:17:04.900 line:90% align:center
<Default><b>♪</b></Default>

c0000425
00:17:04.980 --> 00:17:06.150 line:90% align:center
<Default><b>[door slides open]</b></Default>

c0000426
00:17:06.280 --> 00:17:07.490 line:90% align:center
<Default><b>[JHIN]
We can use her.</b></Default>

c0000427
00:17:08.320 --> 00:17:09.660 line:90% align:center
<Default><b>[door slides shut]</b></Default>

c0000428
00:17:18.000 --> 00:17:19.250 line:90% align:center
<Default><b>[elevator bell dings]</b></Default>

c0000429
00:17:19.500 --> 00:17:20.670 line:90% align:center
<Default><b>[door slides open]</b></Default>

c0000430
00:17:22.460 --> 00:17:24.130 line:90% align:center
<Default><b>[door slides shut]</b></Default>

c0000431
00:17:29.680 --> 00:17:30.720 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000432
00:17:31.300 --> 00:17:33.050 line:90% align:center
<Default><b>[SOLDIER] Master Grugell?
Is something wrong?</b></Default>

c0000433
00:17:34.010 --> 00:17:37.390 line:90% align:center
<Default><b>It felt like an irritating fly
was buzzing around my ear.</b></Default>

c0000434
00:17:37.600 --> 00:17:39.940 line:90% align:center
<Default><b>I suppose
I must have imagined it.</b></Default>

c0000435
00:17:40.560 --> 00:17:41.600 line:90% align:center
<Default><b>-Huh?
-Hmm.</b></Default>

c0000436
00:17:41.940 --> 00:17:44.110 line:90% align:center
<Default><b>[footfall]</b></Default>

c0000437
00:17:51.450 --> 00:17:52.450 line:90% align:center
<Default><b>♪</b></Default>

c0000438
00:17:52.530 --> 00:17:53.950 line:90% align:center
<Default><b>[door slides open]</b></Default>

c0000439
00:17:54.530 --> 00:17:57.540 line:90% align:center
<Default><b>[escalator whirring]</b></Default>

c0000440
00:18:04.330 --> 00:18:06.300 line:90% align:center
<Default><b>Nami, how much longer now?</b></Default>

c0000441
00:18:06.960 --> 00:18:08.920 line:90% align:center
<Default><b>I'd say we have less
than an hour, give or take.</b></Default>

c0000442
00:18:10.920 --> 00:18:11.930 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000443
00:18:23.230 --> 00:18:24.690 line:90% align:center
<Default><b>[JHIN]
It's eerily quiet.</b></Default>

c0000444
00:18:25.400 --> 00:18:26.980 line:90% align:center
<Default><b>[ISKA] Yeah.
Too quiet</b></Default>

c0000445
00:18:28.230 --> 00:18:30.030 line:90% align:center
<Default><b>Do you sense Sisbell nearby?</b></Default>

c0000446
00:18:30.490 --> 00:18:31.860 line:90% align:center
<Default><b>I don't hear anything.</b></Default>

c0000447
00:18:32.110 --> 00:18:34.360 line:90% align:center
<Default><b>Wherever she might be,
it's not on this floor.</b></Default>

c0000448
00:18:34.740 --> 00:18:35.780 line:90% align:center
<Default><b>[Nami gasps]</b></Default>

c0000449
00:18:36.200 --> 00:18:38.040 line:90% align:center
<Default><b>Not here?
So, does that mean...?</b></Default>

c0000450
00:18:38.700 --> 00:18:39.910 line:90% align:center
<Default><b>[CYSTEA]
One floor above us.</b></Default>

c0000451
00:18:40.290 --> 00:18:41.870 line:90% align:center
<Default><b>I'm picking up
someone breathing.</b></Default>

c0000452
00:18:42.790 --> 00:18:44.330 line:90% align:center
<Default><b>It doesn't sound like
they're moving.</b></Default>

c0000453
00:18:44.750 --> 00:18:45.830 line:90% align:center
<Default><b>So they're either trapped,</b></Default>

c0000454
00:18:46.170 --> 00:18:48.250 line:90% align:center
<Default><b>or they're stationary
for whatever reason.</b></Default>

c0000455
00:18:48.880 --> 00:18:50.760 line:90% align:center
<Default><b>Our lady.
It has to be.</b></Default>

c0000456
00:18:51.720 --> 00:18:54.510 line:90% align:center
<Default><b>Gotta work our way up there
before we draw any conclusions.</b></Default>

c0000457
00:18:54.760 --> 00:18:57.300 line:90% align:center
<Default><b>Whether it's Sisbell
or the enemy waiting for us,</b></Default>

c0000458
00:18:57.390 --> 00:18:58.390 line:90% align:center
<Default><b>we'll deal with it.</b></Default>

c0000459
00:18:58.970 --> 00:19:00.930 line:90% align:center
<Default><b>But how do we find a way up?</b></Default>

c0000460
00:19:01.020 --> 00:19:02.850 line:90% align:center
<Default><b>It's not accessible
by elevator.</b></Default>

c0000461
00:19:03.600 --> 00:19:04.690 line:90% align:center
<Default><b>We'll find a way.</b></Default>

c0000462
00:19:04.770 --> 00:19:06.690 line:90% align:center
<Default><b>My bets are on this floor
being the key.</b></Default>

c0000463
00:19:07.610 --> 00:19:09.440 line:90% align:center
<Default><b>Tch!
You've gotta be kidding me.</b></Default>

c0000464
00:19:10.110 --> 00:19:11.820 line:90% align:center
<Default><b>This is too irritating.</b></Default>

c0000465
00:19:12.400 --> 00:19:13.860 line:90% align:center
<Default><b>[NAMI] [gasps]
They left it open?</b></Default>

c0000466
00:19:15.030 --> 00:19:16.110 line:90% align:center
<Default><b>Everyone follow me.</b></Default>

c0000467
00:19:16.200 --> 00:19:17.200 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000468
00:19:21.200 --> 00:19:22.200 line:90% align:center
<Default><b>Hang on a sec!</b></Default>

c0000469
00:19:22.330 --> 00:19:24.080 line:90% align:center
<Default><b>I don't know
if that's a good idea!</b></Default>

c0000470
00:19:24.670 --> 00:19:26.540 line:90% align:center
<Default><b>Take it easy,
I'll be extra careful.</b></Default>

c0000471
00:19:29.630 --> 00:19:30.630 line:90% align:center
<Default><b>A trap?</b></Default>

c0000472
00:19:30.750 --> 00:19:31.760 line:90% align:center
<Default><b>An ambush?</b></Default>

c0000473
00:19:32.170 --> 00:19:34.420 line:90% align:center
<Default><b>Why lead us to the top floor,
with no issue?</b></Default>

c0000474
00:19:38.390 --> 00:19:39.720 line:90% align:center
<Default><b>[VICHYSSOISE]
Well, well!</b></Default>

c0000475
00:19:39.930 --> 00:19:41.720 line:90% align:center
<Default><b>If it isn't Grandma Grugell.</b></Default>

c0000476
00:19:41.890 --> 00:19:42.890 line:90% align:center
<Default><b>Hmm.</b></Default>

c0000477
00:19:43.020 --> 00:19:44.230 line:90% align:center
<Default><b>[GRUGELL]
Vichyssoise.</b></Default>

c0000478
00:19:44.730 --> 00:19:45.770 line:90% align:center
<Default><b>That's me!</b></Default>

c0000479
00:19:46.100 --> 00:19:48.060 line:90% align:center
<Default><b>Nice to see you
on your feet, granny.</b></Default>

c0000480
00:19:48.400 --> 00:19:50.690 line:90% align:center
<Default><b>I heard some mongrels
really roughed you up.</b></Default>

c0000481
00:19:51.400 --> 00:19:53.030 line:90% align:center
<Default><b>[GRUGELL]
How long has this brat</b></Default>

c0000482
00:19:53.110 --> 00:19:54.610 line:90% align:center
<Default><b>been snooping around?</b></Default>

c0000483
00:19:55.530 --> 00:19:57.570 line:90% align:center
<Default><b>Hm?
What do you want?</b></Default>

c0000484
00:19:57.740 --> 00:19:59.450 line:90% align:center
<Default><b>I'm not interested
in little girls,</b></Default>

c0000485
00:19:59.530 --> 00:20:00.910 line:90% align:center
<Default><b>so enough with your gawking.</b></Default>

c0000486
00:20:01.240 --> 00:20:03.450 line:90% align:center
<Default><b>Come back in another 40 years.</b></Default>

c0000487
00:20:03.830 --> 00:20:04.960 line:90% align:center
<Default><b>[chuckles softly]</b></Default>

c0000488
00:20:05.290 --> 00:20:07.000 line:90% align:center
<Default><b>So you are the real deal.</b></Default>

c0000489
00:20:07.290 --> 00:20:09.750 line:90% align:center
<Default><b>Here I thought we had
a fake snooping around.</b></Default>

c0000490
00:20:10.210 --> 00:20:12.050 line:90% align:center
<Default><b>[GRUGELL]
Speak plainly, girl.</b></Default>

c0000491
00:20:12.500 --> 00:20:13.630 line:90% align:center
<Default><b>It's all here.</b></Default>

c0000492
00:20:14.420 --> 00:20:15.470 line:90% align:center
<Default><b>But it's heightened.</b></Default>

c0000493
00:20:15.550 --> 00:20:16.680 line:90% align:center
<Default><b>Ever since I became a witch,</b></Default>

c0000494
00:20:16.760 --> 00:20:19.470 line:90% align:center
<Default><b>I can practically
sniff out astral spirits.</b></Default>

c0000495
00:20:19.930 --> 00:20:21.310 line:90% align:center
<Default><b>Speaking of which, granny,</b></Default>

c0000496
00:20:21.430 --> 00:20:23.640 line:90% align:center
<Default><b>you got the stench
of strange astral energy</b></Default>

c0000497
00:20:23.720 --> 00:20:25.430 line:90% align:center
<Default><b>clinging all over you,
you know that?</b></Default>

c0000498
00:20:26.060 --> 00:20:27.230 line:90% align:center
<Default><b>Need I remind you,</b></Default>

c0000499
00:20:27.310 --> 00:20:29.400 line:90% align:center
<Default><b>this is a research facility
for astral spirits--</b></Default>

c0000500
00:20:29.480 --> 00:20:32.020 line:90% align:center
<Default><b>[VICHYSSOISE] Kinda smells like
the Lou's vacation house.</b></Default>

c0000501
00:20:32.480 --> 00:20:33.690 line:90% align:center
<Default><b>Where were you today?</b></Default>

c0000502
00:20:34.820 --> 00:20:37.740 line:90% align:center
<Default><b>I was right here in
this building the entire time.</b></Default>

c0000503
00:20:38.280 --> 00:20:39.530 line:90% align:center
<Default><b>Fine.</b></Default>

c0000504
00:20:39.740 --> 00:20:42.200 line:90% align:center
<Default><b>Guess that means
they already infiltrated us.</b></Default>

c0000505
00:20:42.490 --> 00:20:43.330 line:90% align:center
<Default><b>[Grugell gasps]</b></Default>

c0000506
00:20:43.410 --> 00:20:44.830 line:90% align:center
<Default><b>Must be nice to have servants</b></Default>

c0000507
00:20:44.910 --> 00:20:46.410 line:90% align:center
<Default><b>with some pretty
convenient powers,</b></Default>

c0000508
00:20:46.500 --> 00:20:47.500 line:90% align:center
<Default><b>-don't ya think?
-[gasps]</b></Default>

c0000509
00:20:48.540 --> 00:20:51.080 line:90% align:center
<Default><b>Be a good granny
and report to Lord Talisman.</b></Default>

c0000510
00:20:51.590 --> 00:20:52.590 line:90% align:center
<Default><b>And to...</b></Default>

c0000511
00:20:52.920 --> 00:20:55.590 line:90% align:center
<Default><b>the acting head of Hydra,
Lady Mizerhyby.</b></Default>

c0000512
00:20:57.170 --> 00:20:58.840 line:90% align:center
<Default><b>[MASKED LORD]
I'm afraid you misunderstand,</b></Default>

c0000513
00:20:58.930 --> 00:20:59.930 line:90% align:center
<Default><b>Lord Talisman.</b></Default>

c0000514
00:21:00.260 --> 00:21:01.090 line:90% align:center
<Default><b>Hmm?</b></Default>

c0000515
00:21:01.220 --> 00:21:02.390 line:90% align:center
<Default><b>[LORD]
While I did imply</b></Default>

c0000516
00:21:02.470 --> 00:21:04.390 line:90% align:center
<Default><b>the Sovereignty needs
a stronger leader,</b></Default>

c0000517
00:21:04.520 --> 00:21:07.140 line:90% align:center
<Default><b>I did not say anything
about the Queen's election.</b></Default>

c0000518
00:21:08.020 --> 00:21:09.020 line:90% align:center
<Default><b>[chuckles softly]</b></Default>

c0000519
00:21:09.940 --> 00:21:12.110 line:90% align:center
<Default><b>We simply need
to awaken the Founder.</b></Default>

c0000520
00:21:12.270 --> 00:21:13.270 line:90% align:center
<Default><b>Come again?</b></Default>

c0000521
00:21:13.360 --> 00:21:14.570 line:90% align:center
<Default><b>Out of the question!</b></Default>

c0000522
00:21:14.780 --> 00:21:16.440 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000523
00:21:16.610 --> 00:21:18.320 line:90% align:center
<Default><b>[indistinct chatter]</b></Default>

c0000524
00:21:18.450 --> 00:21:20.160 line:90% align:center
<Default><b>I didn't consider that.</b></Default>

c0000525
00:21:20.530 --> 00:21:22.530 line:90% align:center
<Default><b>Imagine the potential
in our hands!</b></Default>

c0000526
00:21:23.240 --> 00:21:24.620 line:90% align:center
<Default><b>[MASKED LORD]
Are we all in agreement?</b></Default>

c0000527
00:21:25.160 --> 00:21:26.330 line:90% align:center
<Default><b>No, we are not!</b></Default>

c0000528
00:21:27.160 --> 00:21:29.540 line:90% align:center
<Default><b>We have yet to establish
a way to awaken the Founder,</b></Default>

c0000529
00:21:29.620 --> 00:21:30.670 line:90% align:center
<Default><b>and even then,</b></Default>

c0000530
00:21:30.790 --> 00:21:32.670 line:90% align:center
<Default><b>awakening her
comes with a risk.</b></Default>

c0000531
00:21:34.340 --> 00:21:36.670 line:90% align:center
<Default><b>I beg you all to
remember the damage done</b></Default>

c0000532
00:21:36.760 --> 00:21:38.220 line:90% align:center
<Default><b>to the neutral city of Ein.</b></Default>

c0000533
00:21:39.260 --> 00:21:40.260 line:90% align:center
<Default><b>Hm.</b></Default>

c0000534
00:21:40.590 --> 00:21:42.010 line:90% align:center
<Default><b>[ALICE]
The Founder won't think twice</b></Default>

c0000535
00:21:42.090 --> 00:21:44.720 line:90% align:center
<Default><b>about hurting our own people
to destroy the Empire.</b></Default>

c0000536
00:21:45.060 --> 00:21:46.220 line:90% align:center
<Default><b>Consider those caught</b></Default>

c0000537
00:21:46.310 --> 00:21:48.100 line:90% align:center
<Default><b>in the crossfire
of the Founder's fury.</b></Default>

c0000538
00:21:48.520 --> 00:21:51.060 line:90% align:center
<Default><b>We would be condemned
if innocent lives were lost.</b></Default>

c0000539
00:21:51.270 --> 00:21:52.940 line:90% align:center
<Default><b>I can think
of no better scenario</b></Default>

c0000540
00:21:53.020 --> 00:21:54.270 line:90% align:center
<Default><b>for a Queen to step in.</b></Default>

c0000541
00:21:54.730 --> 00:21:56.650 line:90% align:center
<Default><b>♪</b></Default>

c0000542
00:21:56.940 --> 00:21:58.030 line:90% align:center
<Default><b>[gasps]</b></Default>

c0000543
00:22:00.030 --> 00:22:01.200 line:90% align:center
<Default><b>[ALICE]
Did something happen?</b></Default>

c0000544
00:22:03.200 --> 00:22:05.660 line:90% align:center
<Default><b>[MISMIS] This place looks
straight out of a dream.</b></Default>

c0000545
00:22:08.790 --> 00:22:10.040 line:90% align:center
<Default><b>-I hear something.
-[ALL] Huh?</b></Default>

c0000546
00:22:10.580 --> 00:22:12.710 line:90% align:center
<Default><b>Sounds like it's coming
from that structure.</b></Default>

c0000547
00:22:14.790 --> 00:22:15.790 line:90% align:center
<Default><b>[MISMIS]
Up there?</b></Default>

c0000548
00:22:17.800 --> 00:22:18.800 line:90% align:center
<Default><b>[ALL]
Hm.</b></Default>

c0000549
00:22:22.800 --> 00:22:24.470 line:90% align:center
<Default><b>Sisbell's inside this thing?</b></Default>

c0000550
00:22:24.890 --> 00:22:25.930 line:90% align:center
<Default><b>It's possible.</b></Default>

c0000551
00:22:26.310 --> 00:22:27.720 line:90% align:center
<Default><b>What I heard
matches the profile</b></Default>

c0000552
00:22:27.810 --> 00:22:28.850 line:90% align:center
<Default><b>of a young woman.</b></Default>

c0000553
00:22:29.100 --> 00:22:30.640 line:90% align:center
<Default><b>-Are you certain?
-Well, then, it has to be her.</b></Default>

c0000554
00:22:32.270 --> 00:22:33.310 line:90% align:center
<Default><b>[thuds]</b></Default>

c0000555
00:22:33.600 --> 00:22:34.690 line:90% align:center
<Default><b>What was that?</b></Default>

c0000556
00:22:35.060 --> 00:22:36.190 line:90% align:center
<Default><b>[NENE]
An explosion?</b></Default>

c0000557
00:22:36.570 --> 00:22:37.480 line:90% align:center
<Default><b>[JHIN]
Why now?</b></Default>

c0000558
00:22:37.610 --> 00:22:38.780 line:90% align:center
<Default><b>Any clue who's down there?</b></Default>

c0000559
00:22:39.190 --> 00:22:41.240 line:90% align:center
<Default><b>No!
We're not sure what's going on.</b></Default>

c0000560
00:22:41.650 --> 00:22:43.860 line:90% align:center
<Default><b>This is beyond anything
we prepared for!</b></Default>

c0000561
00:22:44.530 --> 00:22:45.530 line:90% align:center
<Default><b>What's that?</b></Default>

c0000562
00:22:46.240 --> 00:22:47.370 line:90% align:center
<Default><b>Astral energy?</b></Default>

c0000563
00:22:48.040 --> 00:22:49.040 line:90% align:center
<Default><b>[ALL]
Ah!</b></Default>

c0000564
00:22:49.620 --> 00:22:51.580 line:90% align:center
<Default><b>[ISKA] Why turn
the entire royal family</b></Default>

c0000565
00:22:51.660 --> 00:22:53.460 line:90% align:center
<Default><b>against you
by wrecking Hydra's base?</b></Default>

c0000566
00:22:53.830 --> 00:22:56.500 line:90% align:center
<Default><b>Even Alice was careful about
playing her hand too heavily.</b></Default>

c0000567
00:22:56.790 --> 00:22:58.090 line:90% align:center
<Default><b>That's the reason
she asked for our help</b></Default>

c0000568
00:22:58.170 --> 00:22:59.170 line:90% align:center
<Default><b>in the first place.</b></Default>

c0000569
00:23:00.630 --> 00:23:01.800 line:90% align:center
<Default><b>Who's down there?</b></Default>

c0000570
00:23:02.340 --> 00:23:03.590 line:90% align:center
<Default><b>Let's get Sisbell and go,</b></Default>

c0000571
00:23:03.930 --> 00:23:05.090 line:90% align:center
<Default><b>while the guards are outside.</b></Default>

c0000572
00:23:05.680 --> 00:23:07.180 line:90% align:center
<Default><b>Security isn't
as tight right now.</b></Default>

c0000573
00:23:07.260 --> 00:23:08.390 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000574
00:23:09.390 --> 00:23:10.430 line:90% align:center
<Default><b>Break her out!</b></Default>

c0000575
00:23:10.770 --> 00:23:11.770 line:90% align:center
<Default><b>You got it.</b></Default>

c0000576
00:23:12.600 --> 00:23:13.730 line:90% align:center
<Default><b>[gunshot fires]</b></Default>

c0000577
00:23:15.020 --> 00:23:16.190 line:90% align:center
<Default><b>[clanking]</b></Default>

c0000578
00:23:16.480 --> 00:23:17.480 line:90% align:center
<Default><b>[shatters]</b></Default>

c0000579
00:23:26.820 --> 00:23:27.870 line:90% align:center
<Default><b>Lady Sisbell!</b></Default>

c0000580
00:23:28.030 --> 00:23:29.160 line:90% align:center
<Default><b>[CYSTEA]
Are you injured?</b></Default>

c0000581
00:23:29.700 --> 00:23:30.700 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000582
00:23:32.700 --> 00:23:34.620 line:90% align:center
<Default><b>[chair creaks]</b></Default>

c0000583
00:23:36.330 --> 00:23:37.330 line:90% align:center
<Default><b>[all gasp]</b></Default>

c0000584
00:23:37.420 --> 00:23:38.420 line:90% align:center
<Default><b>[chuckles softly]</b></Default>

c0000585
00:23:41.130 --> 00:23:42.130 line:90% align:center
<Default><b>[snaps fingers]</b></Default>

c0000586
00:23:42.340 --> 00:23:43.920 line:90% align:center
<Default><b>A swift execution.</b></Default>

c0000587
00:23:44.550 --> 00:23:46.470 line:90% align:center
<Default><b>[rumbling]</b></Default>

c0000588
00:23:46.590 --> 00:23:48.930 line:90% align:center
<Default><b>[gunshots firing]</b></Default>

c0000589
00:23:49.010 --> 00:23:51.560 line:90% align:center
<Default><b>Pleasure to meet you,
Lou's assassin.</b></Default>

c0000590
00:23:52.770 --> 00:23:53.810 line:90% align:center
<Default><b>This gun is designed</b></Default>

c0000591
00:23:53.890 --> 00:23:56.020 line:90% align:center
<Default><b>to condense astral energy
into rays.</b></Default>

c0000592
00:23:56.650 --> 00:23:58.400 line:90% align:center
<Default><b>I have 24 of them.</b></Default>

c0000593
00:23:59.230 --> 00:24:01.360 line:90% align:center
<Default><b>A prototype from
this very facility.</b></Default>

c0000594
00:24:01.440 --> 00:24:02.990 line:90% align:center
<Default><b>I guarantee its strength.</b></Default>

c0000595
00:24:03.740 --> 00:24:04.780 line:90% align:center
<Default><b>After all,</b></Default>

c0000596
00:24:05.070 --> 00:24:07.070 line:90% align:center
<Default><b>it uses my astral energy.</b></Default>

c0000597
00:24:07.820 --> 00:24:10.410 line:90% align:center
<Default><b>Mizerhyby Hydra Nebulis IX.</b></Default>

c0000598
00:24:10.490 --> 00:24:11.990 line:90% align:center
<Default><b>The pleasure is yours.</b></Default>

c0000599
00:24:12.450 --> 00:24:13.450 line:90% align:center
<Default><b>Come.</b></Default>

c0000600
00:24:13.700 --> 00:24:14.710 line:90% align:center
<Default><b>Allow me to show you</b></Default>

c0000601
00:24:14.790 --> 00:24:17.290 line:90% align:center
<Default><b>the most dignified power
to grace this planet.</b></Default>

c0000602
00:24:17.620 --> 00:24:18.750 line:90% align:center
<Default><b>[giggles]</b></Default>

c0000603
00:24:19.790 --> 00:24:22.800 line:90% align:center
<Default><b>[electricity crackling]</b></Default>

c0000604
00:24:25.420 --> 00:24:28.510 line:90% align:center
<Default><b>Please, welcome me
with a round of applause!</b></Default>

