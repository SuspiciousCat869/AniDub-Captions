background-color: #00000000;
}

c0000000
00:00:01.420 --> 00:00:02.880 line:90% align:center
<Default><b>[door creaks]</b></Default>

c0000001
00:00:02.960 --> 00:00:05.010 line:90% align:center
<Default><b>- Kaede, it's about time
to get up.</b></Default>

c0000002
00:00:05.090 --> 00:00:06.380 line:90% align:center
<Default><b>Breakfast is almost ready.</b></Default>

c0000003
00:00:06.470 --> 00:00:08.220 line:90% align:center
<Default><b>- [groaning]</b></Default>

c0000004
00:00:10.260 --> 00:00:11.390 line:90% align:center
<Default><b>[gasps]
Who are you?</b></Default>

c0000005
00:00:11.470 --> 00:00:12.800 line:90% align:center
<Default><b>- Huh?
- [gasps]</b></Default>

c0000006
00:00:12.890 --> 00:00:14.350 line:90% align:center
<Default><b>Hold on.
What is this place?</b></Default>

c0000007
00:00:14.430 --> 00:00:15.850 line:90% align:center
<Default><b>And I--huh?</b></Default>

c0000008
00:00:15.930 --> 00:00:17.140 line:90% align:center
<Default><b>What is all of this?</b></Default>

c0000009
00:00:18.100 --> 00:00:19.100 line:90% align:center
<Default><b>- Kaede?</b></Default>

c0000010
00:00:20.650 --> 00:00:23.610 line:90% align:center
<Default><b>- [singing in Japanese]</b></Default>

c0000011
00:00:23.690 --> 00:00:26.530 line:90% align:center
<Default><b>[The Peggies' "Kimi no sei"]</b></Default>

c0000012
00:00:26.610 --> 00:00:33.530 line:90% align:center
<Default><b>♪ ♪</b></Default>

c0000013
00:01:08.940 --> 00:01:15.870 line:90% align:center
<Default><b>♪ ♪</b></Default>

c0000014
00:01:35.300 --> 00:01:42.190 line:90% align:center
<Default><b>♪ ♪</b></Default>

c0000015
00:01:51.190 --> 00:01:53.780 line:90% align:center
<Default><b>- The symptoms Kaede has
are likely due to a type</b></Default>

c0000016
00:01:53.860 --> 00:01:55.410 line:90% align:center
<Default><b>of dissociative disorder.</b></Default>

c0000017
00:01:55.490 --> 00:01:57.780 line:90% align:center
<Default><b>- Could you explain
what that is?</b></Default>

c0000018
00:01:57.870 --> 00:02:00.580 line:90% align:center
<Default><b>- It's an illness where one
loses their sense of self</b></Default>

c0000019
00:02:00.660 --> 00:02:02.750 line:90% align:center
<Default><b>and their previously-held
consciousness.</b></Default>

c0000020
00:02:02.830 --> 00:02:05.420 line:90% align:center
<Default><b>Some patients--
as is the case with Kaede--</b></Default>

c0000021
00:02:05.500 --> 00:02:07.540 line:90% align:center
<Default><b>experience other symptoms
as well.</b></Default>

c0000022
00:02:07.630 --> 00:02:10.460 line:90% align:center
<Default><b>This can include the omission
of or loss of memories.</b></Default>

c0000023
00:02:10.550 --> 00:02:13.720 line:90% align:center
<Default><b>Right now your child
is unaware of who you are.</b></Default>

c0000024
00:02:13.800 --> 00:02:15.890 line:90% align:center
<Default><b>She has no memories
of any of you.</b></Default>

c0000025
00:02:16.180 --> 00:02:17.930 line:90% align:center
<Default><b>- [grunts]
Why would such a--</b></Default>

c0000026
00:02:18.310 --> 00:02:21.220 line:90% align:center
<Default><b>- It is believed that extreme
stress or psychological trauma</b></Default>

c0000027
00:02:21.310 --> 00:02:22.430 line:90% align:center
<Default><b>can cause this to happen.</b></Default>

c0000028
00:02:23.770 --> 00:02:25.810 line:90% align:center
<Default><b>- Kaede developed
her puberty syndrome</b></Default>

c0000029
00:02:25.900 --> 00:02:28.980 line:90% align:center
<Default><b>initially because people
were saying terrible things</b></Default>

c0000030
00:02:29.070 --> 00:02:30.690 line:90% align:center
<Default><b>about her on social media,
right?</b></Default>

c0000031
00:02:31.070 --> 00:02:32.150 line:90% align:center
<Default><b>- That's right.</b></Default>

c0000032
00:02:32.530 --> 00:02:34.360 line:90% align:center
<Default><b>- It was traumatizing for her.</b></Default>

c0000033
00:02:34.820 --> 00:02:36.820 line:90% align:center
<Default><b>- She went through
so much suffering.</b></Default>

c0000034
00:02:36.910 --> 00:02:39.790 line:90% align:center
<Default><b>So much that she decided
to sever part of her memory.</b></Default>

c0000035
00:02:39.870 --> 00:02:42.620 line:90% align:center
<Default><b>It was the only way left
she felt she could escape.</b></Default>

c0000036
00:02:42.700 --> 00:02:45.500 line:90% align:center
<Default><b>To protect herself before
she completely broke.</b></Default>

c0000037
00:02:45.580 --> 00:02:47.420 line:90% align:center
<Default><b>- So that's what happened.</b></Default>

c0000038
00:02:47.500 --> 00:02:49.340 line:90% align:center
<Default><b>- When Kaede lost her memory,</b></Default>

c0000039
00:02:49.420 --> 00:02:51.090 line:90% align:center
<Default><b>I didn't know how
to interact with her.</b></Default>

c0000040
00:02:51.590 --> 00:02:52.840 line:90% align:center
<Default><b>I was lost at first.</b></Default>

c0000041
00:02:54.050 --> 00:02:55.050 line:90% align:center
<Default><b>Kaede.</b></Default>

c0000042
00:02:55.130 --> 00:02:56.680 line:90% align:center
<Default><b>I brought a book.</b></Default>

c0000043
00:02:56.760 --> 00:02:59.010 line:90% align:center
<Default><b>The new volume to that series
you were excited for.</b></Default>

c0000044
00:02:59.100 --> 00:03:00.260 line:90% align:center
<Default><b>Here.</b></Default>

c0000045
00:03:00.350 --> 00:03:03.020 line:90% align:center
<Default><b>- Th--thank you very much
for this.</b></Default>

c0000046
00:03:03.100 --> 00:03:04.390 line:90% align:center
<Default><b>So, uh...</b></Default>

c0000047
00:03:04.850 --> 00:03:07.480 line:90% align:center
<Default><b>Kaede was a fan
of this book series?</b></Default>

c0000048
00:03:07.560 --> 00:03:09.230 line:90% align:center
<Default><b>- [gasps]</b></Default>

c0000049
00:03:10.610 --> 00:03:12.400 line:90% align:center
<Default><b>She talks differently.</b></Default>

c0000050
00:03:12.480 --> 00:03:14.950 line:90% align:center
<Default><b>She holds chopsticks with
the other hand.</b></Default>

c0000051
00:03:15.030 --> 00:03:17.410 line:90% align:center
<Default><b>She eats each dish in
a different order than before.</b></Default>

c0000052
00:03:17.740 --> 00:03:19.740 line:90% align:center
<Default><b>She buttons her pajamas
from the top.</b></Default>

c0000053
00:03:19.830 --> 00:03:21.370 line:90% align:center
<Default><b>She walks differently.</b></Default>

c0000054
00:03:21.450 --> 00:03:23.450 line:90% align:center
<Default><b>She's different from Kaede.</b></Default>

c0000055
00:03:23.540 --> 00:03:25.210 line:90% align:center
<Default><b>Different. Different.</b></Default>

c0000056
00:03:25.290 --> 00:03:26.960 line:90% align:center
<Default><b>Everything about her
is different.</b></Default>

c0000057
00:03:28.920 --> 00:03:30.750 line:90% align:center
<Default><b>I'm home.
- [gasps]</b></Default>

c0000058
00:03:30.840 --> 00:03:32.050 line:90% align:center
<Default><b>Welcome home.
- Kaede.</b></Default>

c0000059
00:03:32.130 --> 00:03:33.050 line:90% align:center
<Default><b>[gasps]</b></Default>

c0000060
00:03:36.170 --> 00:03:37.510 line:90% align:center
<Default><b>You here, Mom? It's Kaede.</b></Default>

c0000061
00:03:37.590 --> 00:03:39.090 line:90% align:center
<Default><b>She has bruises all over
her body again.</b></Default>

c0000062
00:03:40.260 --> 00:03:41.850 line:90% align:center
<Default><b>- Oh, I see.</b></Default>

c0000063
00:03:43.390 --> 00:03:46.480 line:90% align:center
<Default><b>No need to worry, Kaede.</b></Default>

c0000064
00:03:46.940 --> 00:03:49.270 line:90% align:center
<Default><b>- [gasps]
- It'll all turn out okay.</b></Default>

c0000065
00:03:49.350 --> 00:03:52.270 line:90% align:center
<Default><b>- Our mom wasn't able
to accept what had happened</b></Default>

c0000066
00:03:52.360 --> 00:03:55.110 line:90% align:center
<Default><b>to Kaede and became
mentally ill herself.</b></Default>

c0000067
00:03:55.990 --> 00:03:57.530 line:90% align:center
<Default><b>And as for me...</b></Default>

c0000068
00:03:57.610 --> 00:03:59.820 line:90% align:center
<Default><b>[groaning]
[squelching]</b></Default>

c0000069
00:03:59.910 --> 00:04:01.200 line:90% align:center
<Default><b>[groans]</b></Default>

c0000070
00:04:01.280 --> 00:04:03.740 line:90% align:center
<Default><b>[gasping]</b></Default>

c0000071
00:04:06.790 --> 00:04:08.710 line:90% align:center
<Default><b>I was taken to the hospital.</b></Default>

c0000072
00:04:09.170 --> 00:04:11.250 line:90% align:center
<Default><b>But nobody believed what I had
to say at all.</b></Default>

c0000073
00:04:12.040 --> 00:04:14.590 line:90% align:center
<Default><b>I tried to explain but they
assumed it was mental,</b></Default>

c0000074
00:04:14.670 --> 00:04:16.260 line:90% align:center
<Default><b>that I convinced myself,</b></Default>

c0000075
00:04:16.340 --> 00:04:18.050 line:90% align:center
<Default><b>and that my wounds
were self-inflicted.</b></Default>

c0000076
00:04:19.760 --> 00:04:21.430 line:90% align:center
<Default><b>They couldn't do anything.</b></Default>

c0000077
00:04:21.970 --> 00:04:23.640 line:90% align:center
<Default><b>They couldn't do anything
for Kaede.</b></Default>

c0000078
00:04:25.600 --> 00:04:27.230 line:90% align:center
<Default><b>One day I just got sick
of it all</b></Default>

c0000079
00:04:27.310 --> 00:04:29.440 line:90% align:center
<Default><b>and decided to sneak out
of the hospital.</b></Default>

c0000080
00:04:29.520 --> 00:04:31.560 line:90% align:center
<Default><b>That's when I met her.</b></Default>

c0000081
00:04:33.820 --> 00:04:35.570 line:90% align:center
<Default><b>- Hey, did you know?</b></Default>

c0000082
00:04:35.650 --> 00:04:38.150 line:90% align:center
<Default><b>If you measured the distance
to the horizon seen</b></Default>

c0000083
00:04:38.240 --> 00:04:41.660 line:90% align:center
<Default><b>at human eye level,
it'd be roughly four kilometers?</b></Default>

c0000084
00:04:42.780 --> 00:04:45.700 line:90% align:center
<Default><b>- Shoko-san stood quietly
and listened to my story,</b></Default>

c0000085
00:04:45.790 --> 00:04:47.500 line:90% align:center
<Default><b>and she believed every bit.</b></Default>

c0000086
00:04:48.500 --> 00:04:49.790 line:90% align:center
<Default><b>So from then on,</b></Default>

c0000087
00:04:49.870 --> 00:04:52.000 line:90% align:center
<Default><b>I would sneak out
of the hospital regularly.</b></Default>

c0000088
00:04:52.790 --> 00:04:56.670 line:90% align:center
<Default><b>Go to Shichirigahama Beach,
and Shoko-san would be there.</b></Default>

c0000089
00:04:57.880 --> 00:05:01.180 line:90% align:center
<Default><b>- Were you thinking about your
little sister again as usual?</b></Default>

c0000090
00:05:01.260 --> 00:05:03.600 line:90% align:center
<Default><b>- I was actually thinking
about you, Shoko-san.</b></Default>

c0000091
00:05:03.680 --> 00:05:05.760 line:90% align:center
<Default><b>- So you were having
lewd thoughts.</b></Default>

c0000092
00:05:05.850 --> 00:05:07.270 line:90% align:center
<Default><b>- That's not it.</b></Default>

c0000093
00:05:07.350 --> 00:05:08.890 line:90% align:center
<Default><b>I was wondering why you
believed everything I had</b></Default>

c0000094
00:05:08.980 --> 00:05:11.230 line:90% align:center
<Default><b>to say so easily.
- Hmm?</b></Default>

c0000095
00:05:11.310 --> 00:05:13.810 line:90% align:center
<Default><b>- With Kaede's wounds
or my scar,</b></Default>

c0000096
00:05:13.900 --> 00:05:15.860 line:90% align:center
<Default><b>and even about puberty syndrome.</b></Default>

c0000097
00:05:16.440 --> 00:05:17.730 line:90% align:center
<Default><b>I've brought them all up</b></Default>

c0000098
00:05:17.820 --> 00:05:19.740 line:90% align:center
<Default><b>but no one else
took me seriously.</b></Default>

c0000099
00:05:19.820 --> 00:05:21.910 line:90% align:center
<Default><b>Not one person even tried
to believe what I saw</b></Default>

c0000100
00:05:21.990 --> 00:05:23.370 line:90% align:center
<Default><b>with my own two eyes.</b></Default>

c0000101
00:05:24.320 --> 00:05:26.280 line:90% align:center
<Default><b>- I'm sure that there are
as many worlds to see</b></Default>

c0000102
00:05:26.370 --> 00:05:28.950 line:90% align:center
<Default><b>as there are people in them,
I think.</b></Default>

c0000103
00:05:29.410 --> 00:05:32.210 line:90% align:center
<Default><b>Just like how we're both
looking out at the same horizon.</b></Default>

c0000104
00:05:32.290 --> 00:05:34.920 line:90% align:center
<Default><b>But the one you can see is
much further than the one I can.</b></Default>

c0000105
00:05:35.000 --> 00:05:36.170 line:90% align:center
<Default><b>- [gasps]</b></Default>

c0000106
00:05:36.250 --> 00:05:38.300 line:90% align:center
<Default><b>- Same for this ocean breeze.</b></Default>

c0000107
00:05:38.380 --> 00:05:40.510 line:90% align:center
<Default><b>Some people will say
it feels refreshing</b></Default>

c0000108
00:05:40.590 --> 00:05:43.130 line:90% align:center
<Default><b>while others say they dislike it
because it makes their skin</b></Default>

c0000109
00:05:43.220 --> 00:05:44.890 line:90% align:center
<Default><b>and hair feel sticky.</b></Default>

c0000110
00:05:44.970 --> 00:05:46.300 line:90% align:center
<Default><b>I believe it was some sort</b></Default>

c0000111
00:05:46.390 --> 00:05:47.720 line:90% align:center
<Default><b>of fate that brought
us together.</b></Default>

c0000112
00:05:47.810 --> 00:05:49.390 line:90% align:center
<Default><b>And so as your elder,</b></Default>

c0000113
00:05:49.470 --> 00:05:51.560 line:90% align:center
<Default><b>I'm going to give you
a wonderful life tip.</b></Default>

c0000114
00:05:51.640 --> 00:05:53.940 line:90% align:center
<Default><b>- Do people normally say
their own tips are wonderful?</b></Default>

c0000115
00:05:55.400 --> 00:05:57.360 line:90% align:center
<Default><b>- In the beginning I
was like you.</b></Default>

c0000116
00:05:57.440 --> 00:06:00.400 line:90% align:center
<Default><b>I didn't have a big dream
or high hopes for my future.</b></Default>

c0000117
00:06:01.070 --> 00:06:04.110 line:90% align:center
<Default><b>Even still, I was able
to find real meaning in the life</b></Default>

c0000118
00:06:04.200 --> 00:06:05.200 line:90% align:center
<Default><b>that was handed to me.</b></Default>

c0000119
00:06:06.450 --> 00:06:08.370 line:90% align:center
<Default><b>Here's what I think, Sakuta.</b></Default>

c0000120
00:06:08.950 --> 00:06:12.580 line:90% align:center
<Default><b>Life's purpose is to help
us learn to become kinder.</b></Default>

c0000121
00:06:12.660 --> 00:06:15.250 line:90% align:center
<Default><b>- Be kinder?
What do you mean?</b></Default>

c0000122
00:06:15.330 --> 00:06:18.590 line:90% align:center
<Default><b>- The way that I live my life
is hoping that each day</b></Default>

c0000123
00:06:18.670 --> 00:06:21.670 line:90% align:center
<Default><b>that goes by I can say I'm
a slightly kinder person today</b></Default>

c0000124
00:06:21.760 --> 00:06:23.050 line:90% align:center
<Default><b>than I was yesterday.</b></Default>

c0000125
00:06:24.970 --> 00:06:26.340 line:90% align:center
<Default><b>- [shudders]</b></Default>

c0000126
00:06:30.220 --> 00:06:31.680 line:90% align:center
<Default><b>[quietly crying]</b></Default>

c0000127
00:06:32.770 --> 00:06:34.770 line:90% align:center
<Default><b>Can I ask something, Shoko-san?</b></Default>

c0000128
00:06:34.850 --> 00:06:36.270 line:90% align:center
<Default><b>- What is it?</b></Default>

c0000129
00:06:36.560 --> 00:06:40.570 line:90% align:center
<Default><b>- Would it be okay if I try
to live my life like you do?</b></Default>

c0000130
00:06:40.650 --> 00:06:42.740 line:90% align:center
<Default><b>- Oh, yeah.
Of course it would be.</b></Default>

c0000131
00:06:42.820 --> 00:06:44.610 line:90% align:center
<Default><b>Now that you've experienced pain</b></Default>

c0000132
00:06:44.700 --> 00:06:46.450 line:90% align:center
<Default><b>that other people
can't understand,</b></Default>

c0000133
00:06:46.530 --> 00:06:48.990 line:90% align:center
<Default><b>I'm sure you can become kinder
than anyone.</b></Default>

c0000134
00:06:49.080 --> 00:06:50.830 line:90% align:center
<Default><b>I'm certain you could help
give someone else</b></Default>

c0000135
00:06:50.910 --> 00:06:52.000 line:90% align:center
<Default><b>the strength they need.</b></Default>

c0000136
00:06:52.500 --> 00:06:54.290 line:90% align:center
<Default><b>- [whimpers]</b></Default>

c0000137
00:06:54.370 --> 00:06:56.290 line:90% align:center
<Default><b>Those were completely
new values to me.</b></Default>

c0000138
00:06:58.000 --> 00:06:59.670 line:90% align:center
<Default><b>I was released from
the hospital</b></Default>

c0000139
00:06:59.750 --> 00:07:02.340 line:90% align:center
<Default><b>and I bought a single notebook
and a pen before going home.</b></Default>

c0000140
00:07:02.800 --> 00:07:04.130 line:90% align:center
<Default><b>- What's this?</b></Default>

c0000141
00:07:04.220 --> 00:07:06.130 line:90% align:center
<Default><b>- Do you remember what
the doctor said?</b></Default>

c0000142
00:07:06.220 --> 00:07:08.090 line:90% align:center
<Default><b>Yesterday, about writing down
what you thought</b></Default>

c0000143
00:07:08.180 --> 00:07:09.720 line:90% align:center
<Default><b>or what happened that day.</b></Default>

c0000144
00:07:09.800 --> 00:07:11.930 line:90% align:center
<Default><b>All that matters is that you do
it in your own words.</b></Default>

c0000145
00:07:12.020 --> 00:07:13.140 line:90% align:center
<Default><b>- Yeah.</b></Default>

c0000146
00:07:13.220 --> 00:07:14.770 line:90% align:center
<Default><b>- Start by just writing
your name.</b></Default>

c0000147
00:07:14.850 --> 00:07:16.100 line:90% align:center
<Default><b>- Um, all right.</b></Default>

c0000148
00:07:16.810 --> 00:07:18.020 line:90% align:center
<Default><b>- Uh, hold on.</b></Default>

c0000149
00:07:18.100 --> 00:07:19.150 line:90% align:center
<Default><b>- Yes?</b></Default>

c0000150
00:07:19.230 --> 00:07:20.570 line:90% align:center
<Default><b>- About writing your name.</b></Default>

c0000151
00:07:20.650 --> 00:07:23.440 line:90% align:center
<Default><b>- Don't worry about that.
I already know the kanji.</b></Default>

c0000152
00:07:23.530 --> 00:07:26.280 line:90% align:center
<Default><b>It's Kaede spelled using flower
followed with maple like</b></Default>

c0000153
00:07:26.360 --> 00:07:27.610 line:90% align:center
<Default><b>the tree, right?</b></Default>

c0000154
00:07:27.700 --> 00:07:29.740 line:90% align:center
<Default><b>- Let's go with Kaede
in all hiragana.</b></Default>

c0000155
00:07:29.820 --> 00:07:31.330 line:90% align:center
<Default><b>- Hiragana?</b></Default>

c0000156
00:07:31.410 --> 00:07:34.410 line:90% align:center
<Default><b>- The person in front of me
is the current Kaede.</b></Default>

c0000157
00:07:34.500 --> 00:07:35.410 line:90% align:center
<Default><b>- [gasps]</b></Default>

c0000158
00:07:36.960 --> 00:07:38.920 line:90% align:center
<Default><b>- I'm sorry.
I see now.</b></Default>

c0000159
00:07:39.000 --> 00:07:41.540 line:90% align:center
<Default><b>- [crying]</b></Default>

c0000160
00:07:41.630 --> 00:07:44.260 line:90% align:center
<Default><b>Y--you're the only one,
big brother!</b></Default>

c0000161
00:07:44.340 --> 00:07:46.590 line:90% align:center
<Default><b>The only one who
understands Kaede!</b></Default>

c0000162
00:07:46.680 --> 00:07:48.680 line:90% align:center
<Default><b>[crying]</b></Default>

c0000163
