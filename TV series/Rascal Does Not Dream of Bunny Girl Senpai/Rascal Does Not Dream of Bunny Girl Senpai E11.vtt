<Default><b>- [grunting]</b></Default>

c0000548
00:23:19.610 --> 00:23:20.520 line:90% align:center
<Default><b>- Kae?
- [gasps]</b></Default>

c0000549
00:23:21.650 --> 00:23:22.610 line:90% align:center
<Default><b>[gasps]</b></Default>

c0000550
00:23:24.650 --> 00:23:25.820 line:90% align:center
<Default><b>- [gasps]</b></Default>

c0000551
00:23:27.160 --> 00:23:28.370 line:90% align:center
<Default><b>- [whimpers]</b></Default>

c0000552
00:23:30.240 --> 00:23:31.580 line:90% align:center
<Default><b>- You know her?
- [whimpers]</b></Default>

c0000553
00:23:31.660 --> 00:23:32.750 line:90% align:center
<Default><b>Who is she?</b></Default>

c0000554
00:23:32.830 --> 00:23:34.160 line:90% align:center
<Default><b>- [gasps]</b></Default>

c0000555
00:23:34.250 --> 00:23:37.210 line:90% align:center
<Default><b>Kae? Hey, it's me.
Kotomi Kono.</b></Default>

c0000556
00:23:37.290 --> 00:23:38.420 line:90% align:center
<Default><b>You don't remember?</b></Default>

c0000557
00:23:38.500 --> 00:23:40.460 line:90% align:center
<Default><b>- N--no, sorry.</b></Default>

c0000558
00:23:40.540 --> 00:23:41.670 line:90% align:center
<Default><b>Kaede doesn't.</b></Default>

c0000559
00:23:41.750 --> 00:23:43.170 line:90% align:center
<Default><b>- [gasps]</b></Default>

c0000560
00:23:43.260 --> 00:23:44.550 line:90% align:center
<Default><b>-
What's going on?</b></Default>

c0000561
00:23:45.470 --> 00:23:46.380 line:90% align:center
<Default><b>- [grunts]</b></Default>

